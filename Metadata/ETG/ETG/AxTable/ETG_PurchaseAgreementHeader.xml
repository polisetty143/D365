			<Method>
				<Name>modifiedField</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <param name = "_fieldId"></param>
    public void modifiedField(FieldId _fieldId)
    {
        PurchAgreementHeader        purchAgreementHeader;
        super(_fieldId);

        select firstonly purchAgreementHeader
                where purchAgreementHeader.PurchNumberSequence == this.PurchAgreementId;

        switch (_fieldId)
        {
            case fieldNum(ETG_PurchaseAgreementHeader, FromDatePort):
                    if ((this.FromDatePort < purchAgreementHeader.DefaultAgreementLineEffectiveDate ||
                        this.FromDatePort > purchAgreementHeader.DefaultAgreementLineExpirationDate) && this.FromDatePort != dateNull())
                    {
                        throw warning("@ETG:FromDatePortValidation");
                    }
           
                break;

            case fieldNum(ETG_PurchaseAgreementHeader, ToDatePort):
                if ((this.ToDatePort < purchAgreementHeader.DefaultAgreementLineEffectiveDate ||
                    this.ToDatePort > purchAgreementHeader.DefaultAgreementLineExpirationDate) && this.ToDatePort != dateNull())
                {
                    throw warning("@ETG:ToDatePortValidation");
                }
                break;
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>validateWrite</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <returns></returns>
    public boolean validateWrite()
    {
        boolean ret;
        PurchAgreementHeader        purchAgreementHeader;
    
        ret = super();
    
        select firstonly purchAgreementHeader
                where purchAgreementHeader.PurchNumberSequence == this.PurchAgreementId;

        if (this.FromDatePort && (this.FromDatePort < purchAgreementHeader.DefaultAgreementLineEffectiveDate ||
                    this.FromDatePort > purchAgreementHeader.DefaultAgreementLineExpirationDate))
        {
            ret = checkfailed("@ETG:FromDatePortValidation");
        }

        if (this.ToDatePort && (this.ToDatePort < purchAgreementHeader.DefaultAgreementLineEffectiveDate ||
            this.ToDatePort > purchAgreementHeader.DefaultAgreementLineExpirationDate))
        {
            ret = checkfailed("@ETG:ToDatePortValidation");
        }

        return ret;
    }

]]></Source>
