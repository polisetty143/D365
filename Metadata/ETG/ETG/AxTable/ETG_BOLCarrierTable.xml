			<Method>
				<Name>lastLine</Name>
				<Source><![CDATA[
    static int  lastLine(ParmId _parmId)
    {
        return (select maxOf(LineNum) from ETG_BOLCarrierTable
        index hint ParmIdx
            where ETG_BOLCarrierTable.ParmId == _parmId).LineNum;
    }

]]></Source>
			</Method>
			<Method>
				<Name>lastLineNum</Name>
				<Source><![CDATA[
    static int  lastLineNum(WMSBillOfLadingId bolId)
    {
        return (select maxOf(LineNum) from ETG_BOLCarrierTable
            index hint BOLIdx
            where ETG_BOLCarrierTable.BOLId == bolId).LineNum;
    }

]]></Source>
