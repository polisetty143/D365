			<Method>
				<Name>modifiedField</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <param name = "_fieldId"></param>
    public void modifiedField(FieldId _fieldId)
    {
        super(_fieldId);
        switch (_fieldId)
        {
            case fieldNum(ETG_ChargeCodes, Value):
                this.RemainingValue = this.Value;
                this.ValuePerPiece = this.Value/this.Qty;
                break;

            case fieldNum(ETG_ChargeCodes, ValuePerPiece):
                if(this.ValuePerPiece > 0)
                {
                    this.Value = this.ValuePerPiece * this.Qty;
                    this.RemainingValue = this.Value;
                }
                break;
        }
    }

]]></Source>
