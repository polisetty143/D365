				<Name>insert</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public void insert()
    {
        NumberSeq       numSeq;
        NumberSequenceReference numSeqRef;
 
        if(ETGACFParameters::find().EnableDMSIntegration == NoYes::Yes)
        {
            if (!this.ETG_Estimation)
            {
                //SB, DLT, 10/04/2026, commented as number seq is needed for isCLRsession() as well
                /*if (xSession::isCLRSession())         
                {
                    ETG_ChargeCodes lastRec;
                    int lastNum = 0;
                    str nextNum;
 
                    select maxof(ETG_Estimation) from lastRec;
                    if (lastRec.ETG_Estimation)
                    {
                        lastNum = str2int(lastRec.ETG_Estimation);
                    }
 
                    nextNum = int2str(lastNum + 1);
 
                    this.ETG_Estimation = strFmt("%1", nextNum);
                }
                else
                {*/
                    if (this.TableId == tableNum(ETGCodeChargesSaleEntity))
                    {
                        numSeqRef = SalesParameters::numReEstimstion();
                    }
                    else
                    {
                        numSeqRef = PurchParameters::numReEstimstion();
                    }
 
                    if (numSeqRef)
                    {
                        numSeq = NumberSeq::newGetNum(numSeqRef);
 
                        if (numSeq)
                        {
                            this.ETG_Estimation = numSeq.num();
                        }
                    }
                //}
            }
        }
 
        this.RemainingValue = this.Value;
        super();
    }

]]></Source>
