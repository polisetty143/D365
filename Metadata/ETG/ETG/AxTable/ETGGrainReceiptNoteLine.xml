			<Method>
				<Name>delete</Name>
				<Source><![CDATA[
    public void delete()
    {
        ETGGrainReceiptNoteTable header;
        header = ETGGrainReceiptNoteTable::findFromGrainReceiptNote(this.GrainReceiptNoteId, true);

        super();
        if (header)
        {
            ttsbegin;
            header.calculateTotals();
            header.recalcNetAmountPayable();
            header.update();
            ttscommit;
        }
    }

