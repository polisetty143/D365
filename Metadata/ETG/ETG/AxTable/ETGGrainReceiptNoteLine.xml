				<Source><![CDATA[
    public void modifiedField(FieldId _fieldId)
    {
        super(_fieldId);

        if (_fieldId == fieldNum(ETGGrainReceiptNoteLine, Qty) ||
        _fieldId == fieldNum(ETGGrainReceiptNoteLine, Price))
        {
            this.LineAmount = this.Qty * this.Price;

            ETGGrainReceiptNoteTable header =
                ETGGrainReceiptNoteTable::findFromGrainReceiptNote(this.GrainReceiptNoteId, true);

            if (header)
            {
                header.calculateTotals();
                header.update();
            }
        }
    }

]]></Source>
