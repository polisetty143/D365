		<Methods>
			<Method>
				<Name>findFromTimelineTable</Name>
				<Source><![CDATA[
    /// <summary>
    /// This method finds a particular record in Timeline Table
    /// </summary>
    /// <param name = "origin">ETGTimelineOrigin origin</param>
    /// <param name = "destination">ETGDestination destination</param>
    /// <param name = "_forUpdate">boolean _forUpdate</param>
    /// <returns>ETGTimelineTable</returns>
    static ETGTimelineTable findFromTimelineTable(ETGTimelineOrigin origin, ETGDestination destination, boolean _forUpdate = false)
    {
        ETGTimelineTable timelineTable;

        timelineTable.selectForUpdate(_forUpdate);

        select firstonly timelineTable
            where timelineTable.ETGTimelineOrigin == origin 
                && timelineTable.ETGDestination == destination;

        return timelineTable;
    }

]]></Source>
			</Method>
			<Method>
				<Name>validateWrite</Name>
				<Source><![CDATA[
    /// <summary>
    /// This method validates to not allow same Origin and Destination combination
    /// </summary>
    /// <returns>boolean</returns>
    public boolean validateWrite()
    {
        boolean ret = super();
        if(ret && this.ETGTimelineOrigin == this.ETGDestination )
        {
            throw error("@ETG_New:OriginDestCanNotSame");
        }
    
        return ret;
    }

]]></Source>
			</Method>
		</Methods>
