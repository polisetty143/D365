                break;

            case fieldNum(ETGAgrrementQualitySpecsLine, MinRange) :
                 
                select firstonly RecId  from etgQualitySpecificationLineGroup
                    where etgQualitySpecificationLineGroup.RecId != this.RecId
                        && etgQualitySpecificationLineGroup.AgreementLineRefrecid == this.AgreementLineRefrecid
                        && etgQualitySpecificationLineGroup.GroupID         == this.GroupID
                        && etgQualitySpecificationLineGroup.MeasurementType == this.MeasurementType
                        &&  etgQualitySpecificationLineGroup.MinRange       <= this.MinRange
                        && etgQualitySpecificationLineGroup.MaxRange        >= this.MinRange  ;

                if (etgQualitySpecificationLineGroup)
                {
                    ret = false;
                    Error('@ETG_New:ETGThisMinMaxRangewasalreadyexist');
                }
                
                if ( this.MaxRange < this.MinRange)
                {
                    ret = false;
                    Error('@ETG_New:ETGMaxvalueshouldbegreaterthanminvalue');
                }
                
                break;
            
        }

      
    
        return ret;
