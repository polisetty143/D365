				<Name>find</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    static ETG_CustExchRateAdjSimulation find(TransDate _ETG_ConsiderDate,TransDate _ETG_DateOfRate,CustVendExchPrinciples _ETG_CustVendExchPrinciples,
                         CustAccount _AccountNum,Name _AccountName,CurrencyCode _currencyCode,TransDate TransDate,AmountMst AmountCur,
                         AmountMst CurBalance,AmountMst NewBalance,AmountMst ExchangeAdj,AmountMST ExchangeRate,
                         AmountMST CurrentBalanceReporting,AmountMST NewBalanceReporting,AmountMST ExchangeAdjReporting,
                         AmountMST ExchangeRateReporting,NoYesId ETGFinalSimulation)
    {
        ETG_CustExchRateAdjSimulation eTG_CustExchRateAdjSimulation;

        select eTG_CustExchRateAdjSimulation
         where eTG_CustExchRateAdjSimulation.ETG_ConsiderDate           == _ETG_ConsiderDate
            && eTG_CustExchRateAdjSimulation.ETG_DateOfRate             == _ETG_DateOfRate
            && eTG_CustExchRateAdjSimulation.ETG_CustVendExchPrinciples == _ETG_CustVendExchPrinciples
            && eTG_CustExchRateAdjSimulation.AccountNum                 == _AccountNum
            && eTG_CustExchRateAdjSimulation.CurrencyCode               == _currencyCode
            && eTG_CustExchRateAdjSimulation.TransDate                  == TransDate
            && eTG_CustExchRateAdjSimulation.AmountCur                  == AmountCur
            && eTG_CustExchRateAdjSimulation.CurBalance                 == CurBalance
            && eTG_CustExchRateAdjSimulation.NewBalance                 == NewBalance
            && eTG_CustExchRateAdjSimulation.ExchangeAdj                == ExchangeAdj
            && eTG_CustExchRateAdjSimulation.ExchangeRate               == ExchangeRate
            && eTG_CustExchRateAdjSimulation.CurrentBalanceReporting    == CurrentBalanceReporting
            && eTG_CustExchRateAdjSimulation.NewBalanceReporting        == NewBalanceReporting
            && eTG_CustExchRateAdjSimulation.ExchangeAdjReporting       == ExchangeAdjReporting
            && eTG_CustExchRateAdjSimulation.ExchangeRateReporting      == ExchangeRateReporting
            && eTG_CustExchRateAdjSimulation.ETGFinalSimulation         == ETGFinalSimulation;

        return eTG_CustExchRateAdjSimulation;

    }

]]></Source>
