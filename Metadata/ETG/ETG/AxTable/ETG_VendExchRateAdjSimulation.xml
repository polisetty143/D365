		<Methods>
			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    static ETG_VendExchRateAdjSimulation find(TransDate _ETG_ConsiderDate,TransDate _ETG_DateOfRate,CustVendExchPrinciples _ETG_CustVendExchPrinciples,
                         CustAccount _AccountNum,Name _AccountName,CurrencyCode _currencyCode,TransDate TransDate,AmountMst AmountCur,
                         AmountMst CurBalance,AmountMst NewBalance,AmountMst ExchangeAdj,AmountMST ExchangeRate,
                         AmountMST CurrentBalanceReporting,AmountMST NewBalanceReporting,AmountMST ExchangeAdjReporting,
                         AmountMST ExchangeRateReporting,NoYesId ETGFinalSimulation,Voucher voucher)
    {
        ETG_VendExchRateAdjSimulation eTG_VendExchRateAdjSimulation;

        select eTG_VendExchRateAdjSimulation
         where eTG_VendExchRateAdjSimulation.ETG_ConsiderDate           == _ETG_ConsiderDate
            && eTG_VendExchRateAdjSimulation.ETG_DateOfRate             == _ETG_DateOfRate
            && eTG_VendExchRateAdjSimulation.ETG_CustVendExchPrinciples == _ETG_CustVendExchPrinciples
            && eTG_VendExchRateAdjSimulation.AccountNum                 == _AccountNum
            && eTG_VendExchRateAdjSimulation.CurrencyCode               == _currencyCode
            && eTG_VendExchRateAdjSimulation.TransDate                  == TransDate
            && eTG_VendExchRateAdjSimulation.AmountCur                  == AmountCur
            && eTG_VendExchRateAdjSimulation.CurBalance                 == CurBalance
            && eTG_VendExchRateAdjSimulation.NewBalance                 == NewBalance
            && eTG_VendExchRateAdjSimulation.ExchangeAdj                == ExchangeAdj
            && eTG_VendExchRateAdjSimulation.ExchangeRate               == ExchangeRate
            && eTG_VendExchRateAdjSimulation.CurrentBalanceReporting    == CurrentBalanceReporting
            && eTG_VendExchRateAdjSimulation.NewBalanceReporting        == NewBalanceReporting
            && eTG_VendExchRateAdjSimulation.ExchangeAdjReporting       == ExchangeAdjReporting
            && eTG_VendExchRateAdjSimulation.ExchangeRateReporting      == ExchangeRateReporting
            && eTG_VendExchRateAdjSimulation.ETGFinalSimulation         == ETGFinalSimulation
            && eTG_VendExchRateAdjSimulation.Voucher                    == voucher;


        return eTG_VendExchRateAdjSimulation;

    }

]]></Source>
