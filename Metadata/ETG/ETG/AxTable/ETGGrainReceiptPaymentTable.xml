			<Method>
				<Name>modifiedField</Name>
				<Source><![CDATA[
    public void modifiedField(FieldId _fieldId)
    {
        super(_fieldId);

        if (_fieldId == fieldNum(ETGGrainReceiptPaymentTable, Percentage))
        {
            ETGGrainReceiptNoteTable header;

            header = ETGGrainReceiptNoteTable::findFromGrainReceiptNote(this.GrainReceiptNoteId, false);

            if (header && header.calcNetAmountPayable() != 0)
            {
                this.PaymentAmount = ((header.calcNetAmountPayable() * this.Percentage) / 100);
            }
            else
            {
                this.PaymentAmount = 0;
            }
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>getNextLineNum</Name>
				<Source><![CDATA[
    public LineNum getNextLineNum()
    {
        ETGGrainReceiptPaymentTable pay;
        LineNum maxLineNum = 0;

        select maxof(LineNumber) from pay
        where pay.GrainReceiptNoteId == this.GrainReceiptNoteId;

        maxLineNum = pay.LineNumber;

        return maxLineNum + 1;  
    }

]]></Source>
			</Method>
			<Method>
				<Name>insert</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public void insert()
    {
        if (!this.LineNumber)
        {
            this.LineNumber = this.getNextLineNum();
        }

        super();
    }

]]></Source>
			</Method>
