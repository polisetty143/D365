		<Methods>
			<Method>
				<Name>amountPayable</Name>
				<Source><![CDATA[
        [SysClientCacheDataMethodAttribute(true)]
    /// <summary>
    /// display method for Amount payable.
    /// </summary>
    public display Amount amountPayable()
    {
        MarkupTrans        _markupTrans;
        PurchLine          purchLine = PurchLine::findRecId(this.PurchLineRecId);
        MonetaryDocumentLineMap monetaryDocumentLine;
        AmountCur           _amount;

        monetaryDocumentLine = MonetaryDocumentLineMap::initFromCommon(purchLine);

        select _markupTrans
            where _markupTrans.TransRecId == purchLine.RecId
            && _markupTrans.TransTableId == purchLine.TableId;

        _amount = Markup::calcMarkupAmount(_markupTrans,
                                                           monetaryDocumentLine.Qty,
                                                           monetaryDocumentLine.LineAmount,
                                                           0,
                                                           purchLine.MonetaryDocumentLineMap::inclTax(),
                                                           NoYes::No,                                   // Default value
                                                           _markupTrans.CurrencyCode,                   // Default value
                                                           _markupTrans.TransDate,                      // Default value
                                                           0,                                           // Default value
                                                           0,                                           // Default value
                                                           null,                                        // Default value
                                                           false,                                       // Default value
                                                           0,                                           // Default value
                                                           '',                                          // Default value
                                                           false,                                       // Default value
                                                           false);
            
        // this.AmountPayable = purchLine.LineAmount + _amount + this.PremiumValue - this.BicAmount - this.Onaccount;

        //Code added by ravi for cocoa report

        this.AmountPayable = purchLine.LineAmount + this.TransportPrice + this.PremiumValue - this.BicAmount - this.Onaccount;

        return this.AmountPayable;
    }

]]></Source>
			</Method>
			<Method>
				<Name>dispPurchLineAmount</Name>
				<Source><![CDATA[
    [SysClientCacheDataMethodAttribute(true)]
    public display LineAmount dispPurchLineAmount()
    {
        PurchLine purchLineLocal;
        select firstonly LineAmount from purchLineLocal
        where purchLineLocal.RecId == this.PurchLineRecId;
        
        return purchLineLocal.LineAmount;
    }

]]></Source>
			</Method>
