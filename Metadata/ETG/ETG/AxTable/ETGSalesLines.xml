				<Name>modifiedField</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <param name = "_fieldId"></param>
    public void modifiedField(FieldId _fieldId)
    {
        super(_fieldId);

        if(this.SalesPrice)
        {
            this.SalesLineAmount = this.SalesOrderedQty * this.SalesPrice;
        }

        if(this.ItemIdSmall)
        {
            this.SalesUnit = InventTableModule::find(this.ItemIdSmall, ModuleInventPurchSales::Sales).UnitId;
        }

        if(this.ItemIdSmall)
        {
            this.TaxItemGroup = InventTableModule::find(this.ItemIdSmall, ModuleInventPurchSales::Sales).TaxItemGroupId;
        }

        if(this.ETGConnectionType != ETGConnectionType::NewConnectionorCylinder)
        {
            this.ETGDepositAmount = 0;
        }

        if(this.SalesOrderedQty)
        {
            this.ETGDepositAmount = this.ETGDepositRate * this.SalesOrderedQty;
        }
        if(this.ETGDepositRate)
        {
            this.ETGDepositAmount = this.ETGDepositRate * this.SalesOrderedQty;
        }
        TaxGroupData taxGroupData;

        if(this.TaxGroup)
        {
            select * from taxGroupData where taxGroupData.TaxGroup == this.TaxGroup;
            TaxValue tacValue = taxGroupData.showTaxValue();
            if(tacValue)
            {
                real totalInv = this.SalesOrderedQty * this.SalesPrice;
                real priceB = totalInv * tacValue/100;
                real calculation = totalInv + priceB;
                this.SalesLineAmount = calculation;
            }
            else
            {
                real totalInvoice = this.SalesOrderedQty * this.SalesPrice;
                this.SalesLineAmount = totalInvoice;
            }
        }
        else
        {
            real totalInvoice1 = this.SalesOrderedQty * this.SalesPrice;
            this.SalesLineAmount = totalInvoice1;
        }
    }

]]></Source>
