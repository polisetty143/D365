			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    static ETG_BankCurrencyRevData find(LegalEntityRecId _LegalEntity,CompanyBankAccountId _BankAccountId,
                                          MainAccountRecId _MainAccount,LedgerDimensionAccount _BankLedgerDimension,
                                          ExchangeRateTypeRecId _ExchangeRateType,TransDate _ExchangeRateDate,
                                          TransDate _TransDate,AmountMST _AccountingCurrencyAmount,
                                          AmountMST _AccountingCurrencyAdjustmentAmount,
                                          CurrencyCode _BankCurrencyCode,
                                          AmountMST _BankCurrencyAmount,
                                          AmountMST  _ReportingCurrencyAdjustmentAmount)
    {
        ETG_BankCurrencyRevData eTG_BankCurrencyRevalData;

        select eTG_BankCurrencyRevalData
            where eTG_BankCurrencyRevalData.LegalEntity == _LegalEntity &&
            eTG_BankCurrencyRevalData.BankAccountId == _BankAccountId &&
            eTG_BankCurrencyRevalData.MainAccount == _MainAccount &&
            eTG_BankCurrencyRevalData.BankLedgerDimension == _BankLedgerDimension &&
            eTG_BankCurrencyRevalData.ExchangeRateType == _ExchangeRateType &&
            eTG_BankCurrencyRevalData.ExchangeRateDate == _ExchangeRateDate &&
             eTG_BankCurrencyRevalData.TransDate == _TransDate &&
            eTG_BankCurrencyRevalData.AccountingCurrencyAmount == _AccountingCurrencyAmount &&
            eTG_BankCurrencyRevalData.AccountingCurrencyAdjustmentAmount == _AccountingCurrencyAdjustmentAmount &&
            eTG_BankCurrencyRevalData.BankCurrencyCode == _BankCurrencyCode &&
             eTG_BankCurrencyRevalData.BankCurrencyAmount == _BankCurrencyAmount &&
            eTG_BankCurrencyRevalData.ReportingCurrencyAdjustmentAmount == _ReportingCurrencyAdjustmentAmount ;

        return eTG_BankCurrencyRevalData;
    }

]]></Source>
