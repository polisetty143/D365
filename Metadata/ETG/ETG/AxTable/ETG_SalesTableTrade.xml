				<Name>sellerName</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public display VendName sellerName()
    {
        Name    sellerName;

        if (this.SellerAccountNum)
        {
            sellerName = Companyinfo::findDataArea(this.SellerAccountNum).name();
        }

        return sellerName;
       
    }

]]></Source>
			</Method>
			<Method>
				<Name>buyerName</Name>
				<Source><![CDATA[
    public display Name buyerName()
    {
        Name    buyerName;

        if (this.BuyerAccountNum)
        {
            buyerName = CustTable::find(this.BuyerAccountNum).name();
        }

        return buyerName;
    }

]]></Source>
			</Method>
			<Method>
				<Name>brokerName</Name>
				<Source><![CDATA[
    public display VendName brokerName()
    {
        Name    brokerName;

        if (this.Through)
        {
            brokerName = VendTable::find(this.Through).name();
        }

        return brokerName;
    }

]]></Source>
			</Method>
			<Method>
				<Name>findFromSalesTrade</Name>
				<Source><![CDATA[
    /// <summary>
    /// This method finds a particular record in SalesTrade Table
    /// </summary>
    /// <param name = "termoNumber">ETG_SalesTableTrade salesTradeTable</param>
    /// <param name = "_forUpdate">boolean _forUpdate</param>
    /// <returns>ETG_SalesTableTrade</returns>
    static ETG_SalesTableTrade findFromSalesTrade( SalesId salesId, boolean _forUpdate = false)
    {
        ETG_SalesTableTrade salesTradeTable;

        salesTradeTable.selectForUpdate(_forUpdate);

        select firstonly salesTradeTable
            where salesTradeTable.SalesId == salesId;

        return salesTradeTable;
    }

]]></Source>
