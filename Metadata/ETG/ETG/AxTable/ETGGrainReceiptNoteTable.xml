			<Method>
				<Name>calcNetAmountPayable</Name>
				<Source><![CDATA[
    public real calcNetAmountPayable()
    {
        ETGGrainReceiptNoteLine line;
        ETGGrainReceiptCharges charge;

        select sum(LineAmount)
        from line
        where line.GrainReceiptNoteId == this.GrainReceiptNoteId;

        select sum(Amount)
        from charge
        where charge.GrainReceiptNoteId == this.GrainReceiptNoteId;

        return line.LineAmount - charge.Amount;
    }

]]></Source>
			</Method>
			<Method>
				<Name>NetAmountPayableDisplay</Name>
				<Source><![CDATA[
    display real NetAmountPayableDisplay()
    {
        return this.calcNetAmountPayable();
    }

]]></Source>
