			<Method>
				<Name>NetPurchAmtDisplay</Name>
				<Source><![CDATA[
    display real NetPurchAmtDisplay()
    {
        ETGGrainReceiptNoteLine line;

        select sum(LineAmount)
        from line
        where line.GrainReceiptNoteId == this.GrainReceiptNoteId;

        return line.LineAmount;
    }

]]></Source>
