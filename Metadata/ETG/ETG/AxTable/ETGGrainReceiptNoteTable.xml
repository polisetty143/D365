		<Methods>
			<Method>
				<Name>findFromGrainReceiptNote</Name>
				<Source><![CDATA[
    /// <summary>
    /// This method finds a particular record in GrainReceiptNote Table
    /// </summary>
    /// <param name = "grainReceiptNote">ETGGrainReceiptNoteId GrainReceiptNoteId</param>
    /// <param name = "_forUpdate">boolean _forUpdate</param>
    /// <returns>ETGGrainReceiptNoteId</returns>
    static ETGGrainReceiptNoteTable findFromGrainReceiptNote(ETGGrainReceiptNoteId grainReceiptId, boolean _forUpdate = false)
    {
        ETGGrainReceiptNoteTable grainReceiptNoteTable;

        grainReceiptNoteTable.selectForUpdate(_forUpdate);

        select firstonly grainReceiptNoteTable
            where grainReceiptNoteTable.GrainReceiptNoteId == grainReceiptId;

        return grainReceiptNoteTable;
    }

]]></Source>
			</Method>
			<Method>
				<Name>calculateTotals</Name>
				<Source><![CDATA[
    public void calculateTotals()
    {
        ETGGrainReceiptNoteLine line;
        real totalAmount = 0.00;
        real totalQty    = 0.00;
        real split =0.00;
        real doc =0.00;

        while select sum(LineAmount), sum(Qty) 
        from line
        where line.GrainReceiptNoteId == this.GrainReceiptNoteId
        {
            totalAmount = line.LineAmount;
            totalQty    = line.Qty;
        }

        this.NetPurchAmt = totalAmount;    
    }

]]></Source>
			</Method>
			<Method>
				<Name>recalcNetAmountPayable</Name>
				<Source><![CDATA[
    public void recalcNetAmountPayable()
    {
        ETGGrainReceiptPaymentTable pay;
        real netAmountPayable = this.calcNetAmountPayable();

        ttsbegin;

        while select forupdate pay
        where pay.GrainReceiptNoteId == this.GrainReceiptNoteId
        {
            if (pay.Percentage != 0)
            {
                pay.PaymentAmount =
                round((netAmountPayable * pay.Percentage) / 100, 2);

                pay.update();
            }
        }

        ttscommit;
    }

]]></Source>
			</Method>
			<Method>
				<Name>findLevyChargeCode</Name>
				<Source><![CDATA[
    public static MarkupCode findLevyChargeCode()
    {
        MarkupTable markup;

        select firstonly markup
        where markup.ETGLevyChargesApplicable == NoYes::Yes;

        if (markup)
        return markup.MarkupCode;

        return '';
    }

]]></Source>
