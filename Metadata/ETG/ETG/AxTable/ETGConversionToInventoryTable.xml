			<Method>
				<Name>lookupProductDimension</Name>
				<Source><![CDATA[
    public static void lookupProductDimension(FormControl _formControl, ItemId _itemId, FieldId _fieldId)
    {
        if(_itemId == "")
        {
            throw Error("@ETG_New:ItemNumValidation");
        }

        Query                  query = new Query();
        QueryBuildRange        queryBuildRange;
        QueryBuildDataSource   queryBuildDataSource  = query.addDataSource(tableNum(RetailProductVariantDimensionsView));
        SysTableLookup         tableLookup           = SysTableLookup::newParameters(tablenum(RetailProductVariantDimensionsView), _formControl);
        tableLookup.addLookupfield(_fieldId);
        queryBuildDataSource.orderMode(OrderMode::GroupBy);
        queryBuildDataSource.addGroupByField(_fieldId);
        queryBuildRange = queryBuildDataSource.addrange(fieldNum(RetailProductVariantDimensionsView, ItemId));
        queryBuildRange.value(_itemId);
        tableLookup.parmQuery(query);
        tableLookup.performFormLookup();

    }

]]></Source>
			</Method>
