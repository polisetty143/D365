    /// </summary>
    /// <param name = "_fieldId"></param>
    public void modifiedField(FieldId _fieldId)
    {
        super(_fieldId);

        switch (_fieldId)
        {
            case fieldNum(ETGConversionToInventoryTable,InventLocationId) :
            if(this.InventLocationId != " ")
                {
                    this.InventSiteId = InventLocation::find(this.InventLocationId).inventSite().SiteId;
                }
                break;
        }

    }

]]></Source>
