				<Name>modifiedField</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <param name = "_fieldId"></param>
    public void modifiedField(FieldId _fieldId)
    {
        CustTable custTable;

        super(_fieldId);

        select * from custTable
            where custTable.AccountNum == this.CustAccount;

        this.CustCurrencyCode = custTable.Currency;
    }

]]></Source>
			</Method>
			<Method>
				<Name>totalamount</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public display real totalamount()
    {
        ETGSalesLines salesLines;
        select sum(SalesLineAmount) from salesLines
            where salesLines.ETGSalesHeaderRecId == this.RecId;
           
        return salesLines.SalesLineAmount;
    }

]]></Source>
