			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    /// <summary>
    /// QualitySpecificationBugs.,27 Jan 2021,Binay
    /// </summary>
    /// <param name = "_groupId"></param>
    /// <param name = "_forUpdate"></param>
    /// <returns></returns>
    static ETGQualitySpecificationGroup find(ETGQualitySpecificationGroupId   _groupId,boolean       _forUpdate = false)
    {
        ETGQualitySpecificationGroup qualitySpecificationGroup;

        if (_groupId)
        {
            if (_forUpdate)
            {
                qualitySpecificationGroup.selectForUpdate(_forUpdate);
            }

            select firstonly qualitySpecificationGroup
                index hint GroupIdx
                where qualitySpecificationGroup.GroupID == _groupId;
        }

        return qualitySpecificationGroup;
    }

]]></Source>
