        ret = super(_fieldIdToCheck);

        if(ret)
        {
            switch(_fieldIdToCheck)
            {
                case fieldNum(ETGRateCardMaster, DiscPct):
                if(this.DiscPct > 0 && this.DiscAmount > 0)
                    {
                        ret = checkFailed("Only discount percent or discount amount can be applied");
                    }
                    break;
                case fieldNum(ETGRateCardMaster, DiscAmount):
                if(this.DiscPct > 0 && this.DiscAmount > 0)
                    {
                        ret = checkFailed("Only discount percent or discount amount can be applied");
                    }
                    break;
            }
        }
    
        return ret;
    }

