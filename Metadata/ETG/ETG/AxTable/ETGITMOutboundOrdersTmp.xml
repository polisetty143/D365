			<Method>
				<Name>deselectAll</Name>
				<Source><![CDATA[
    internal static void deselectAll(ETGITMOutboundOrdersTmp _tmpShipCreatorTable, ITMTmpCreatorLine  _tmpShipCreatorLine)
    {
        ETGITMOutboundOrdersTmp tmpShipCreatorTable;
        ITMTmpCreatorLine tmpShipCreatorLine;
    
        tmpShipCreatorTable.setTmpData(_tmpShipCreatorTable);
        tmpShipCreatorLine.setTmpData(_tmpShipCreatorLine);
    
        ttsbegin;
    
