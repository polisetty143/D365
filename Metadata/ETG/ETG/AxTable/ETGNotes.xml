			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    static ETGNotes find(boolean _forupdate = false)
    {
        ETGNotes    etgNotes;

        if (_forupdate)
        {
            etgNotes.selectForUpdate(_forupdate);
        }

        select firstonly etgNotes
            index Key
            where etgNotes.Key == 0;

        return etgNotes;
    }

]]></Source>
