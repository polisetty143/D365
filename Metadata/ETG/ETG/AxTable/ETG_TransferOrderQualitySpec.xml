			<Method>
				<Name>validateField</Name>
				<Source><![CDATA[
    public boolean validateField(FieldId _fieldIdToCheck)
    {
        boolean                       ret;
        ETG_TransferOrderQualitySpec    transferOrderQualitySpec;
        ret = super(_fieldIdToCheck);
       
        switch(_fieldIdToCheck)
        {
            case fieldNum(ETG_ProductReceiptQualityGrp, MaxRange) :
                 
                select firstonly RecId  from transferOrderQualitySpec
                    where transferOrderQualitySpec.RecId != this.RecId
                        && transferOrderQualitySpec.InventTransId   == this.InventTransId
                        && transferOrderQualitySpec.GroupID         == this.GroupID
                        && transferOrderQualitySpec.MeasurementType == this.MeasurementType
                        &&  transferOrderQualitySpec.MinRange <= this.MaxRange
                        && transferOrderQualitySpec.MaxRange >= this.MaxRange  ;

                if (transferOrderQualitySpec)
                {
                    ret = false;
                    Error('@ETG_New:ETGThisMinMaxRangewasalreadyexist');
                }
                
                if ( this.MaxRange < this.MinRange)
                {
                    ret = false;
                    Error('@ETG_New:ETGMaxvalueshouldbegreaterthanminvalue');
                }
                
                break;

            case fieldNum(ETG_TransferOrderQualitySpec, MinRange) :
                 
                select firstonly RecId  from transferOrderQualitySpec
                    where transferOrderQualitySpec.RecId != this.RecId
                        && transferOrderQualitySpec.InventTransId   == this.InventTransId
                        && transferOrderQualitySpec.GroupID         == this.GroupID
                        && transferOrderQualitySpec.MeasurementType == this.MeasurementType
                        &&  transferOrderQualitySpec.MinRange <= this.MinRange
                        && transferOrderQualitySpec.MaxRange >= this.MinRange  ;

                if (transferOrderQualitySpec)
                {
                    ret = false;
                    Error('@ETG_New:ETGThisMinMaxRangewasalreadyexist');
                }
                
                if ( this.MaxRange < this.MinRange)
                {
                    ret = false;
                    Error('@ETG_New:ETGMaxvalueshouldbegreaterthanminvalue');
                }
                
                break;

           
            
        }
    
        return ret;
    }

