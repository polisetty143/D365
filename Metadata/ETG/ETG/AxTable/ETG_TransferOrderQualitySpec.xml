				<Name>modifiedField</Name>
				<Source><![CDATA[
    public void modifiedField(FieldId _fieldId)
    {
        super(_fieldId);

        switch(_fieldId)
        {
            case fieldNum(ETG_TransferOrderQualitySpec, ResultValue) :
                if( this.ResultValue > this.MaxRange || this.ResultValue < this.MinRange)
                {
                    this.Invalid = NoYes::Yes;
                }
                else
                {
                    this.Invalid = this.isValidEntry();
                }

                

                break;
        }
    
    }

]]></Source>
			</Method>
			<Method>
				<Name>isValidEntry</Name>
				<Source><![CDATA[
    public boolean isValidEntry()
    {
        ETG_TransferOrderQualitySpec    transferOrderQualitySpec;
        boolean     ret;

        select firstonly  transferOrderQualitySpec
            where transferOrderQualitySpec.RecId != this.RecId
            && transferOrderQualitySpec.TransferId ==  this.TransferId
            && transferOrderQualitySpec.invalid == NoYes::No
           && transferOrderQualitySpec.ResultValue > 0;
        
        if (transferOrderQualitySpec.RecId)
        {
            ret = false;

        }
        else
        {
            ret = false;
        }

        return ret;

    }

]]></Source>
