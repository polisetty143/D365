    public void modifiedField(FieldId _fieldId)
    {
        super(_fieldId);

        switch (_fieldId)
        {
            case fieldNum(ETGTERMONumberForeClosureTable, TERMONumber):
                 if(this.TERMONumber)
                {
                    this.updateTermoNumberForeRefETG();
                }
             break;

        }
    }

