			<Method>
				<Name>updateTermoNumberForeRefETG</Name>
				<Source><![CDATA[
    public void updateTermoNumberForeRefETG()
    {
        ETGTERMONumberTable termoNumberTable = ETGTERMONumberTable::findFromTermoNumber(this.TERMONumber);

        this.RemainingTermoValueReal  = termoNumberTable.RemainingTermoValueReal;
        this.PerformaInvoice          = termoNumberTable.PerformaInvoice;
        this.UCRNumber                = termoNumberTable.UCRNumber;
        this.TERMONumberStatus        = termoNumberTable.TERMONumberStatus;
        this.TypeOfTERMO              = termoNumberTable.TypeOfTERMO;
        this.ImportOrExport           = termoNumberTable.ImportOrExport;
        this.TermoValueReal           = termoNumberTable.TermoValueReal;
        this.MotherTERMOReference     = termoNumberTable.MotherTERMOReference;
    }

