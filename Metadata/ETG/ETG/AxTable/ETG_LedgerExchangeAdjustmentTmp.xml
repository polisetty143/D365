		<Methods>
			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    static ETG_LedgerExchangeAdjustmentTmp find(TransDate FromDate,TransDate ToDate,TransDate ExchangeRateDate,Amount AccountingCurrencyAmount,         
                                                NoYesId IsBalanceSheet,LedgerDimensionAccount LedgerDimension,CurrentOperationsTax PostingLayer,
                                                AmountCur ReportingCurrencyAmount,AmountCur TransactionCurrencyAmount,CurrencyCode TransactionCurrencyCode,
                                                ExchangeRateTypeRecId ExchangeRateType,MainAccountRecId MainAccount,AmountCur AccountingCurrencyAdjustmentAmount,
                                                AmountCur ReportingCurrencyAdjustmentAmount,ExchRate AccountingCurrencyCrossRate,ExchRate ReportingCurrencyCrossRate,
                                                LegalEntityRecId LegalEntity,ExchangeRateTypeRecId ReportingCurrencyExchangeRateType)
    {
        ETG_LedgerExchangeAdjustmentTmp eTG_LedgerExchangeAdjustmentTmp;

        select eTG_LedgerExchangeAdjustmentTmp
            where eTG_LedgerExchangeAdjustmentTmp.FromDate                  == FromDate &&
                  eTG_LedgerExchangeAdjustmentTmp.ToDate                    == ToDate   &&
                  eTG_LedgerExchangeAdjustmentTmp.ExchangeRateDate          == ExchangeRateDate &&
                  eTG_LedgerExchangeAdjustmentTmp.AccountingCurrencyAmount  == AccountingCurrencyAmount &&
                  eTG_LedgerExchangeAdjustmentTmp.IsBalanceSheet            == IsBalanceSheet &&
                  eTG_LedgerExchangeAdjustmentTmp.LedgerDimension           == LedgerDimension &&
                  eTG_LedgerExchangeAdjustmentTmp.PostingLayer              == PostingLayer &&
                  eTG_LedgerExchangeAdjustmentTmp.ReportingCurrencyAmount   == ReportingCurrencyAmount &&
                  eTG_LedgerExchangeAdjustmentTmp.TransactionCurrencyAmount == TransactionCurrencyAmount &&
                  eTG_LedgerExchangeAdjustmentTmp.TransactionCurrencyCode   == TransactionCurrencyCode &&
                  eTG_LedgerExchangeAdjustmentTmp.ExchangeRateType          == ExchangeRateType &&
                  eTG_LedgerExchangeAdjustmentTmp.MainAccount               == MainAccount &&
                  eTG_LedgerExchangeAdjustmentTmp.AccountingCurrencyAdjustmentAmount == AccountingCurrencyAdjustmentAmount &&
                  eTG_LedgerExchangeAdjustmentTmp.ReportingCurrencyAdjustmentAmount  == ReportingCurrencyAdjustmentAmount &&
                  eTG_LedgerExchangeAdjustmentTmp.AccountingCurrencyCrossRate        == AccountingCurrencyCrossRate &&
                  eTG_LedgerExchangeAdjustmentTmp.ReportingCurrencyCrossRate         == ReportingCurrencyCrossRate &&
                  eTG_LedgerExchangeAdjustmentTmp.LegalEntity                        == LegalEntity &&
                  eTG_LedgerExchangeAdjustmentTmp.ReportingCurrencyExchangeRateType  == ReportingCurrencyExchangeRateType;

        return eTG_LedgerExchangeAdjustmentTmp;
                
    }

]]></Source>
