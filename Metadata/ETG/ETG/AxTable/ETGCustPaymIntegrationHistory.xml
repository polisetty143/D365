		<Methods>
			<Method>
				<Name>createFromLedgerJournalTrans</Name>
				<Source><![CDATA[
    /// <summary>
    /// 
    /// </summary>
    public static ETGCustPaymIntegrationHistory createFromLedgerJournalTrans(LedgerJournalTrans ledgerJournalTrans, CurrencyCode currency, ETGCTRMInvoiceReferance ctrmInvRef, LedgerJournalType ledgerJournalType, LineAmount invoiceAmt, AmountCur balanceAmt)
    {
        ETGCustPaymIntegrationHistory custPaymIntegrationHistory;

        custPaymIntegrationHistory.clear();
        custPaymIntegrationHistory.Accounting_System_Payment_Id = ledgerJournalTrans.Voucher;
        custPaymIntegrationHistory.Allocated_Amount             = abs(invoiceAmt);
        custPaymIntegrationHistory.CurrencyCode                 = currency;
        custPaymIntegrationHistory.Invoice_Master_Id            = ctrmInvRef;
        custPaymIntegrationHistory.JournalNum                   = ledgerJournalTrans.JournalNum;
        custPaymIntegrationHistory.PaymReference                = ledgerJournalTrans.PaymReference;
        custPaymIntegrationHistory.Status                       = "Sent";
        custPaymIntegrationHistory.JournalType                  = ledgerJournalType;
        custPaymIntegrationHistory.Due                          = ledgerJournalTrans.Due;
        custPaymIntegrationHistory.TransDate                    = ledgerJournalTrans.TransDate;
        custPaymIntegrationHistory.PaymMode                     = ledgerJournalTrans.PaymMode;

        if(balanceAmt == 0)
        {
            custPaymIntegrationHistory.FullSettlement = NoYes::Yes;
        }
        //else if(balanceAmt == invoiceAmt)
        //{
        //    custPaymIntegrationHistory.WriteOff = NoYes::Yes;
        //    custPaymIntegrationHistory.IsFinalPayment = 'Y';
        //}
        //else if(balanceAmt != invoiceAmt)
        //{
        //    custPaymIntegrationHistory.IsFinalPayment = 'N';
        //}

        if(ledgerJournalTrans.ETGWriteOff == NoYes::Yes)
        {
            custPaymIntegrationHistory.WriteOff       = NoYes::Yes;
            custPaymIntegrationHistory.IsFinalPayment = 'Y';
        }
        else
        {
            custPaymIntegrationHistory.IsFinalPayment = 'N';
        }

        custPaymIntegrationHistory.insert();

        return custPaymIntegrationHistory;
    }

]]></Source>
			</Method>
			<Method>
				<Name>exist</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public static boolean exist(LedgerJournalId journalId, Voucher voucherNum, InvoiceId invoiceId)
    {
        boolean found;

        found = (select firstonly
                     RecId
                from
                     eTGCustPaymIntegrationHistory
                 where
                     eTGCustPaymIntegrationHistory.JournalNum == journalId &&
                     eTGCustPaymIntegrationHistory.Accounting_System_Payment_Id == voucherNum &&
                     eTGCustPaymIntegrationHistory.Invoice_Master_Id == invoiceId).RecId != 0;

        return found;
    }

]]></Source>
			</Method>
		</Methods>
