			<Method>
				<Name>modifiedField</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <param name = "_fieldId"></param>
    public void modifiedField(FieldId _fieldId)
    {
        SalesAgreementHeader        salesAgreementHeader;
        CustTable     custTable;
        super(_fieldId);

        select firstonly salesAgreementHeader
                where salesAgreementHeader.SalesNumberSequence == this.SalesAgreementId;

        switch (_fieldId)
        {
            case fieldNum(ETG_SalesAgreementHeader, FromDatePort):
                if ((this.FromDatePort < salesAgreementHeader.DefaultAgreementLineEffectiveDate ||
                    this.FromDatePort > salesAgreementHeader.DefaultAgreementLineExpirationDate) && this.FromDatePort != dateNull())
                {
                    throw warning("@ETG:FromDatePortValidation");
                }
                break;

            case fieldNum(ETG_SalesAgreementHeader, ToDatePort):
                if ((this.ToDatePort < salesAgreementHeader.DefaultAgreementLineEffectiveDate ||
                    this.ToDatePort > salesAgreementHeader.DefaultAgreementLineExpirationDate) && this.ToDatePort != dateNull())
                {
                    throw warning("@ETG:ToDatePortValidation");
                }
                break;

            case fieldNum(ETG_SalesAgreementHeader, Name):
            if(this.Name)
                {
                    custTable = CustTable::find(this.Name);

                    this.Address = custTable.address();
                }
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>validateWrite</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <returns></returns>
    public boolean validateWrite()
    {
        boolean ret;
        SalesAgreementHeader        salesAgreementHeader;

        ret = super();
    
        select firstonly salesAgreementHeader
                where salesAgreementHeader.SalesNumberSequence == this.SalesAgreementId;

        if ((this.FromDatePort < salesAgreementHeader.DefaultAgreementLineEffectiveDate ||
                    this.FromDatePort > salesAgreementHeader.DefaultAgreementLineExpirationDate)  && this.FromDatePort != dateNull())
        {
            ret = checkfailed("@ETG:FromDatePortValidation");
        }

        if ((this.ToDatePort < salesAgreementHeader.DefaultAgreementLineEffectiveDate ||
                    this.ToDatePort > salesAgreementHeader.DefaultAgreementLineExpirationDate) && this.ToDatePort != dateNull())
        {
            ret = checkfailed("@ETG:ToDatePortValidation");
        }

        return ret;
    }

]]></Source>
