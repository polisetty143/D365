{
}
]]></Declaration>
		<Methods>
			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public static ETGPaymentUploaderTable find(int _settlementNumber, boolean _forUpdate = false)
    {
        ETGPaymentUploaderTable paymentUploaderTable;

        if (_settlementNumber)
        {
            if (_forUpdate)
            {
                paymentUploaderTable.selectForUpdate(_forUpdate);
            }

            select firstonly paymentUploaderTable
                where paymentUploaderTable.SettlementNumber == _settlementNumber;
        }

        return paymentUploaderTable;
    }

]]></Source>
			</Method>
			<Method>
				<Name>exist</Name>
				<Source><![CDATA[
    public static boolean exist(int _settlementNumber)
    {
        return _settlementNumber &&
               (select firstonly RecId from ETGPaymentUploaderTable
                where ETGPaymentUploaderTable.SettlementNumber == _settlementNumber).RecId != 0;
    }

]]></Source>
			</Method>
			<Method>
				<Name>remainAmountCur</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    display AmountCur remainAmountCur()
    {
        AmountCur remainAmount;
        if(this.AccountType == ModuleCustVend::Cust)
        {
            remainAmount = this.transDataCust().remainAmountCur();
        }
        else if(this.AccountType == ModuleCustVend::Vend)
        {
            remainAmount = this.transDataVend().remainAmountCur();
        }
        return remainAmount;
    }

]]></Source>
			</Method>
			<Method>
				<Name>transDataCust</Name>
				<Source><![CDATA[
    public CustTransData transDataCust()
    {
        CustTrans custTransRemainAmount = CustTrans::findByVoucher(this.Voucher);
        return CustVendTransData::construct(custTransRemainAmount);
    }

]]></Source>
			</Method>
			<Method>
				<Name>transDataVend</Name>
				<Source><![CDATA[
    public VendTransData transDataVend()
    {
        VendTrans vendTransRemainAmount;
        select * from vendTransRemainAmount where vendTransRemainAmount.Voucher == this.Voucher;
        return CustVendTransData::construct(vendTransRemainAmount);
    }

]]></Source>
			</Method>
		</Methods>
