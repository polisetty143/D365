	<Name>ETGSPAINUnsoldJournalTrans</Name>
	<SourceCode>
		<Declaration><![CDATA[
/// <summary>
/// Represents a transaction in the ETGSPAIN Unsold Journal.
/// </summary>
/// <remarks>
/// This class is used to manage unsold inventory transactions within the ETGSPAIN module's unsold journal system. It initializes values from the journal table and unsold inventory transactions, sets default values for the transaction, and manages the insertion logic for new records.
/// </remarks>
public class ETGSPAINUnsoldJournalTrans extends common
{    
}
]]></Declaration>
		<Methods>
			<Method>
				<Name>initFromETGSPAINUnsoldJournalTable</Name>
				<Source><![CDATA[
    /// <summary>
    /// Initializes the current transaction record from the provided unsold journal table entry.
    /// </summary>
    /// <param name="_etgspainUnsoldJournalTable">The unsold journal table entry.</param>
    public void initFromETGSPAINUnsoldJournalTable(ETGSPAINUnsoldJournalTable _etgspainUnsoldJournalTable)
    {
        this.JournalId = _etgspainUnsoldJournalTable.JournalId;
    }

]]></Source>
			</Method>
			<Method>
				<Name>initFromETGSPAINUnsoldInventTrans</Name>
				<Source><![CDATA[
    /// <summary>
    /// Initializes the current transaction record from the provided unsold inventory transaction.
    /// </summary>
    /// <param name="_etgspainUnsoldInventTrans">The unsold inventory transaction.</param>
    public void initFromETGSPAINUnsoldInventTrans(ETGSPAINUnsoldInventTrans _etgspainUnsoldInventTrans)
    {
        InventTrans     inventTrans = _etgspainUnsoldInventTrans.inventTrans();

        this.UnsoldQty      = _etgspainUnsoldInventTrans.UnsoldQty;
        this.Unit           = _etgspainUnsoldInventTrans.Unit;                
        this.ItemId         = inventTrans.ItemId;
        this.InventDimId    = inventTrans.inventDimId;
    }

]]></Source>
			</Method>
			<Method>
				<Name>initValue</Name>
				<Source><![CDATA[
    /// <summary>
    /// Sets default values for the unsold journal transaction.
    /// </summary>
    public void initValue()
    {
        super();

        this.TransDate      = DateTimeUtil::getSystemDate(DateTimeUtil::getUserPreferredTimeZone());
        this.InventDimId    = InventDim::findOrCreateBlank().inventDimId;
        this.toInventDimId  = InventDim::findOrCreateBlank().inventDimId;

    }

]]></Source>
			</Method>
			<Method>
				<Name>insert</Name>
				<Source><![CDATA[
    /// <summary>
    /// Inserts the current transaction into the unsold journal. Automatically assigns a line number if one is not set.
    /// </summary>
    public void insert()
    {
        if (! this.LineNum)
        {
            this.LineNum = ETGSPAINUnsoldJournalTrans::lastLineNum(this.JournalId) + 1;
        }

        super();
    }

]]></Source>
			</Method>
			<Method>
				<Name>lastLineNum</Name>
				<Source><![CDATA[
    /// <summary>
    /// Retrieves the last line number for the given journal.
    /// </summary>
    /// <param name="_journalId">The ID of the unsold journal.</param>
    /// <returns>The last line number of the journal.</returns>
    public static LineNum lastLineNum(ETGSPAINUnsoldJournalId _journalId)
    {
        return (select maxof(LineNum) from ETGSPAINUnsoldJournalTrans
                    where ETGSPAINUnsoldJournalTrans.JournalId == _journalId).LineNum;
    }

]]></Source>
			</Method>
		</Methods>
