			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    public static ETGReasonCodes find(SmmQuotationReasonId _reasonId,
                                               boolean              _forupdate = false)
    {
        ETGReasonCodes     reasonCodes;

        if (_reasonId)
        {
            reasonCodes.selectForUpdate(_forupdate);

            select firstonly reasonCodes
                where reasonCodes.ReasonId == _reasonId;
        }

        return reasonCodes;
    }

]]></Source>
