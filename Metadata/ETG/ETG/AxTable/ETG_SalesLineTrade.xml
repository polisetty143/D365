		<Methods>
			<Method>
				<Name>createFromSalesLine</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public void createFromSalesLine(SalesLine salesLine)
    {
        AgreementLine aLineETG;
        this.SalesId            = salesLine.SalesId;
        this.SalesLineRecId     = salesLine.RecId;
        if(salesLine.MatchingAgreementLine)
        {
            aLineETG                 = AgreementLine::find(salesLine.MatchingAgreementLine);
            this.PortOfLoading       = aLineETG.ETGPortOfLoading;
            this.PortOfLoadingDesc   = aLineETG.ETGPortOfLoadingDesc;
            this.PortOfDischarge     = aLineETG.ETGPortOfDischarge;
            this.PortOfDischargeDesc = aLineETG.ETGPortOfDischargeDesc;
            this.SalesAgreementLine  = salesLine.MatchingAgreementLine;
        }
        this.insert();
    }

]]></Source>
			</Method>
		</Methods>
