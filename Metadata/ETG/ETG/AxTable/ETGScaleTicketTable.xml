		<Methods>
			<Method>
				<Name>findFromScaleTicketNumber</Name>
				<Source><![CDATA[
    /// <summary>
    /// This method finds a particular record in ScaleTicket Table
    /// </summary>
    /// <param name = "scaleticketnumber">ETGScaleTicketNumber scaleTicketNumber</param>
    /// <param name = "_forUpdate">boolean _forUpdate</param>
    /// <returns>ETGScaleTicketTable</returns>
    static ETGScaleTicketTable findFromScaleTicketNumber(ETGScaleTicketNumber scaleTicketNum, boolean _forUpdate = false)
    {
        ETGScaleTicketTable scaleTicketTable;

        scaleTicketTable.selectForUpdate(_forUpdate);

        select firstonly scaleTicketTable
            where scaleTicketTable.ScaleTicketNumber == scaleTicketNum;

        return scaleTicketTable;
    }

]]></Source>
			</Method>
			<Method>
				<Name>modifiedField</Name>
				<Source><![CDATA[
    /// <summary>
    /// This method auto populates NET weight when Gross weight and Tear weight is entered and sets RefPurchAgreementNum
    /// </summary>
    /// <param name = "_fieldId"></param>
    public void modifiedField(FieldId _fieldId)
    {
        super(_fieldId);

        switch (_fieldId)
        {
            case fieldNum(ETGScaleTicketTable, Tare):
                    if(this)
                this.Net       = this.Gross - this.Tare;
                break;
            case fieldNum(ETGScaleTicketTable, Gross):
                    if(this)
                this.Net       = this.Gross - this.Tare;
                break;
            case fieldNum(ETGScaleTicketTable, RefPurchAgreementNum):
                PurchAgreementHeader purchAgreementHeader;
                
                select firstonly crossCompany  purchAgreementHeader
            where purchAgreementHeader.PurchNumberSequence == this.RefPurchAgreementNum;

                if (purchAgreementHeader)
                {
                    this.RefPurchAgreementEntity = purchAgreementHeader.VendorDataAreaId;
                }
                break;
            //case fieldNum(ETGScaleTicketTable,BIN):
            //    WMSLocation wmsLocation;
            //    container binValues = str2con(this.BIN,';');

            //    select firstonly wmsLocation
            //        where wmsLocation.wmslocationid == conPeek(binValues,1);

            //    this.Location =  wmsLocation.inventlocationId;
            //    break;
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>validateWrite</Name>
				<Source><![CDATA[
    /// <summary>
    /// This method auto populates NET weight when Gross weight and Tear weight is entered
    /// </summary>
    public boolean validateWrite()
    {
        boolean ret = super();

        this.Net = this.Gross - this.Tare;

        return ret;
    }

]]></Source>
			</Method>
			<Method>
				<Name>update</Name>
				<Source><![CDATA[
    public void update()
    {
        this.Net = this.Gross - this.Tare;
        super();
    }

]]></Source>
