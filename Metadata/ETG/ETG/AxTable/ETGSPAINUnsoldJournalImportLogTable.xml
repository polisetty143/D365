	<SourceCode>
		<Declaration><![CDATA[
/// <summary>
/// Represents the ETGSPAIN Unsold Journal Import Log table, which logs import activities related to unsold inventory journals.
/// </summary>
public class ETGSPAINUnsoldJournalImportLogTable extends common
{    
}
]]></Declaration>
		<Methods>
			<Method>
				<Name>existJournalId</Name>
				<Source><![CDATA[
    /// <summary>
    /// Checks if an import log entry exists for a given journal ID.
    /// </summary>
    /// <param name="_journalId">The ID of the unsold journal entry.</param>
    /// <returns>True if the log entry exists, otherwise false.</returns>
    static boolean existJournalId(ETGSPAINUnsoldJournalId  _journalId)
    {
        return _journalId && (select firstonly RecId from ETGSPAINUnsoldJournalImportLogTable                                    
                                    where ETGSPAINUnsoldJournalImportLogTable.JournalId == _journalId).RecId != 0;
    }

]]></Source>
			</Method>
		</Methods>
