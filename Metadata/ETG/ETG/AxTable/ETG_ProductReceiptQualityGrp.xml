        boolean                       ret;
        ETG_ProductReceiptQualityGrp  productReceiptQualityGrp;
        ret = super(_fieldIdToCheck);
       
        switch(_fieldIdToCheck)
        {
            case fieldNum(ETG_ProductReceiptQualityGrp, MaxRange) :
                 
                select firstonly RecId  from productReceiptQualityGrp
                    where productReceiptQualityGrp.RecId != this.RecId
                        && productReceiptQualityGrp.InventTransId   == this.InventTransId
                        && productReceiptQualityGrp.GroupID         == this.GroupID
                        && productReceiptQualityGrp.MeasurementType == this.MeasurementType
