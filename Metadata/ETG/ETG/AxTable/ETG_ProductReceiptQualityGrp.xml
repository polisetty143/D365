				<Name>isValidEntry</Name>
				<Source><![CDATA[
    public boolean isValidEntry()
    {
        ETG_ProductReceiptQualityGrp    productReceiptQualityGrp;
        boolean     ret;

        select firstonly  productReceiptQualityGrp
            where productReceiptQualityGrp.RecId != this.RecId
            && productReceiptQualityGrp.PurchId ==  this.PurchId
            && productReceiptQualityGrp.Invalid == NoYes::No
            && productReceiptQualityGrp.ResultValue > 0;
        
        if (productReceiptQualityGrp.RecId)
        {
            ret = false;

        }
        else
        {
            ret = false;
        }

        return ret;

    }

]]></Source>
