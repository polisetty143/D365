		<Methods>
			<Method>
				<Name>find</Name>
				<Source><![CDATA[
    //ETGItemStockDataPopulateHelper::generateStockData();
    public static ETGItemStockPDTable find(ItemIdSmall _itemCode,  boolean _forUpdate = false)
   {
       ETGItemStockPDTable itemStock;

       if (_itemCode)
        {
            if (_forUpdate)
            {
                itemStock.selectForUpdate(_forUpdate);
            }

            select firstonly itemStock
                index hint Idx
                where itemStock.itemCode == _itemCode;
        }

        return itemStock;
   }

]]></Source>
