			<Method>
				<Name>validateField</Name>
				<Source><![CDATA[
    public boolean validateField(FieldId _fieldIdToCheck)
    {
        boolean ret;
        ret = super(_fieldIdToCheck);
       
        switch(_fieldIdToCheck)
        {
           
            case fieldNum(ETG_PurchLineQualityGrp, GroupId) :
                this.validateGroupid();
                
                break;
            
        }

      
    
        return ret;
    }

]]></Source>
			</Method>
			<Method>
				<Name>validateGroupid</Name>
				<Source><![CDATA[
    public boolean validateGroupid()
    {
        ETG_PurchLineQualityGrp  purchLineQualityGrp;
        boolean     ret = true;
        select firstonly purchLineQualityGrp
            where purchLineQualityGrp.GroupId == this.GroupId
            && purchLineQualityGrp.InventTransId == this.InventTransId;

        if (purchLineQualityGrp.GroupId)
        {
            ret = false;
            Error ( '@ETG_Labels:DuplicateGroupId');

        }

        return ret;
    }

]]></Source>
