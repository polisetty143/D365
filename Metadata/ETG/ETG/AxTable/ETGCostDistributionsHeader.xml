		<Methods>
			<Method>
				<Name>totalPercentages</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public display int totalPercentages()
    {
        ETGCostDistributionsLines costDistributionsLines;
        select sum(ETGLinePercentage) from costDistributionsLines
            where costDistributionsLines.ETGMainAccount == this.ETGMainAccount
            && costDistributionsLines.ETGRefRecId == this.RecId;

        return costDistributionsLines.ETGLinePercentage;
    }

]]></Source>
