		<Methods>
			<Method>
				<Name>canSubmitToWorkflow</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <param name = "_workflowType"></param>
    /// <returns></returns>
    public boolean canSubmitToWorkflow(str _workflowType = '')
    {
        boolean ret;
        ret = super(_workflowType);

        if(ETGACFParameters::find().EnableSalesInvoiceWorkflow == NoYes::Yes)
        {
            if(this.WorkflowStatus == ETGSalesEditLinesWorkflow::Draft)
            {
                ret = true;
            }
            else 
            {
                ret = false;
            }
        }

        return ret;
    }

]]></Source>
			</Method>
			<Method>
				<Name>updateWorkflowStatus</Name>
				<Source><![CDATA[
    public static void  updateWorkflowStatus(RefRecId recId , ETGSalesEditLinesWorkflow status)
    {
        ETGSalesEditLines customWorkflowTable;

        ttsbegin;
        select forupdate customWorkflowTable
        where customWorkflowTable.RecId == recId;

        customWorkflowTable.WorkflowStatus = status;
        customWorkflowTable.update();
        ttscommit;
        
    }

]]></Source>
			</Method>
			<Method>
				<Name>findRecId</Name>
				<Source><![CDATA[
    /// <summary>
    /// Abhinav - 30012025
    /// </summary>
    static ETGSalesEditLines findRecId(RecId       recId,
                                boolean     _forUpdate = false )
    {

        ETGSalesEditLines ETGSalesEditLines;

        ETGSalesEditLines.selectForUpdate(_forUpdate);

        select ETGSalesEditLines
            where ETGSalesEditLines.RecId == recId;

        return ETGSalesEditLines;
    }

]]></Source>
			</Method>
