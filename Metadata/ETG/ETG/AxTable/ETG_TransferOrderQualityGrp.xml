				<Name>groupDescription</Name>
				<Source><![CDATA[
    public display Name groupDescription()
    {
        ETGQualitySpecificationGroup    qualitySpecificationGroup;

        select firstonly GroupDescription from qualitySpecificationGroup
            where qualitySpecificationGroup.GroupID == this.GroupId;


        return qualitySpecificationGroup.GroupDescription;
    }

]]></Source>
