			<Method>
				<Name>validateField</Name>
				<Source><![CDATA[
    public boolean validateField(FieldId _fieldIdToCheck)
    {
        boolean ret;
        ret = super(_fieldIdToCheck);
       
        switch(_fieldIdToCheck)
        {
           
            case fieldNum(ETG_TransferOrderQualityGrp, GroupId) :
                this.validateGroupid();
                
                break;
            
        }

      
    
        return ret;
    }

]]></Source>
			</Method>
			<Method>
				<Name>validateGroupid</Name>
				<Source><![CDATA[
    public boolean validateGroupid()
    {
        ETG_TransferOrderQualityGrp  transferOrderQualityGrp;
        boolean     ret = true;
        select firstonly transferOrderQualityGrp
            where transferOrderQualityGrp.GroupId == this.GroupId
            && transferOrderQualityGrp.InventTransId == this.InventTransId;

        if (transferOrderQualityGrp.GroupId)
        {
            ret = false;
            Error ( '@ETG_Labels:DuplicateGroupId');

        }

        return ret;
    }

]]></Source>
