		<Methods>
			<Method>
				<Name>modifiedField</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <param name = "_fieldId"></param>
    public void modifiedField(FieldId _fieldId)
    {
        switch (_fieldId)
        {
            case fieldnum(ETGLotInfoDetails, WeightatProcessingExit):
                this.Storageweightloss         = this.WeightatProcessingExit-this.PalletsLotWeight;
                break;

            case fieldnum(ETGLotInfoDetails, PalletsLotWeight):
                this.Storageweightloss                  = this.WeightatProcessingExit-this.PalletsLotWeight;
                this.StorageweightlossPer               = ((this.WeightatProcessingExit-this.PalletsLotWeight)/this.PalletsLotWeight)*100;
                this.VerifiedGrossShippedWeightlossPer  = (this.VerifiedGrossShippedWeightloss/this.PalletsLotWeight)*100;
                this.BillofLadingWeightLoss             = this.BillofLadingWeight - this.PalletsLotWeight;
                this.BillofLadingWeightLossPer          = (this.BillofLadingWeightLoss/this.PalletsLotWeight)*100;
                break;

            case fieldnum(ETGLotInfoDetails, Damaged):
                this.DamagedInsectedamaged              = this.Damaged+this.Insectedamaged;
                break;

            case fieldnum(ETGLotInfoDetails, Insectedamaged):
                this.DamagedInsectedamaged              = this.Damaged+this.Insectedamaged;
                break;

            case fieldnum(ETGLotInfoDetails, Brokenparts):
                this.CRM                                = this.Brokenparts+this.Fragment+this.Brokensmallparts+this.Seedsstickstogether;
                break;

            case fieldnum(ETGLotInfoDetails, Fragment):
                this.CRM                                = this.Brokenparts+this.Fragment+this.Brokensmallparts+this.Seedsstickstogether;
                break;

            case fieldnum(ETGLotInfoDetails, Brokensmallparts):
                this.CRM                                = this.Brokenparts+this.Fragment+this.Brokensmallparts+this.Seedsstickstogether;
                break;

            case fieldnum(ETGLotInfoDetails, Seedsstickstogether):
                this.CRM                                = this.Brokenparts+this.Fragment+this.Brokensmallparts+this.Seedsstickstogether;
                this.Waste                              = this.Growing+this.Seedsstickstogether+this.ForeignItems;
                break;

            case fieldnum(ETGLotInfoDetails, Growing):
                this.Waste                              = this.Growing+this.Seedsstickstogether+this.ForeignItems;
                break;

            case fieldnum(ETGLotInfoDetails, ForeignItems):
                this.Waste                              = this.Growing+this.Seedsstickstogether+this.ForeignItems;
                break;

            case fieldnum(ETGLotInfoDetails, LotsTransferDate):
                this.ProcessingPlantTimeofStorage       = this.LotsTransferDate - this.ProductionDate;
                this.TimeofStoragebeforeStuffing        = this.Stuffingdate - this.LotsTransferDate;
                break;

            case fieldnum(ETGLotInfoDetails, ProductionDate):
                this.ProcessingPlantTimeofStorage       = this.LotsTransferDate - this.ProductionDate;
                break;

            case fieldnum(ETGLotInfoDetails, Stuffingdate):
                this.TimeofStoragebeforeStuffing        = this.Stuffingdate - this.LotsTransferDate;
                break;

            case fieldnum(ETGLotInfoDetails, StuffingWeight):
                this.WharfageWeightLoss                 = this.Wharfage - this.StuffingWeight;
                if(this.StuffingWeight !=0)
                {
                    this.WharfageWeightLossPer          = ((this.Wharfage - this.StuffingWeight)/this.StuffingWeight)*100;
                }
                break;

            case fieldnum(ETGLotInfoDetails, Wharfage):
                this.WharfageWeightLoss                 = this.Wharfage - this.StuffingWeight;
                this.WharfageWeightLossPer              = ((this.Wharfage - this.StuffingWeight)/this.StuffingWeight)*100;
                this.VerifiedGrossShippedWeightloss     = this.VerifiedGrossShippedWeight - this.Wharfage;
                break;

            case fieldnum(ETGLotInfoDetails, VerifiedGrossShippedWeight):
                this.VerifiedGrossShippedWeightloss     = this.VerifiedGrossShippedWeight - this.Wharfage;
        }
    }

]]></Source>
