    /// </summary>
    /// <param name = "_fieldId"></param>
    public void modifiedField(FieldId _fieldId)
    {
       
           
        switch (_fieldId)
        {
            case fieldnum(ETGSalesShipmentCocoa, BillofLadingWeight):
                this.WeightLoss         = this.BillofLadingWeight - this.PalletsLotWeight;
                this.WeightLossPer      = this.WeightLoss - this.PalletsLotWeight;
                break;

            case fieldnum(ETGSalesShipmentCocoa, PalletsLotWeight):
                this.WeightLoss         = this.BillofLadingWeight - this.PalletsLotWeight;
                this.WeightLossPer      = this.WeightLoss - this.PalletsLotWeight;
                break;
                

            
        }
    }

]]></Source>
