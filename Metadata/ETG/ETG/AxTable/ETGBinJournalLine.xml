				<Name>modifiedField</Name>
				<Source><![CDATA[
    /// <summary>
    /// mofies a field upon modification of a field specified.
    /// </summary>
    /// <param name = "_fieldId"></param>
    public void modifiedField(FieldId _fieldId)
    {
        switch (_fieldId)
        {
            case fieldNum(ETGBinJournalLine, BinQty):
                this.DiffereceQty = this.BinQty - this.FGRNQty;
                break;
            case fieldNum(ETGBinJournalLine, FGRNQty):
                this.DiffereceQty = this.BinQty - this.FGRNQty;
                break;
        }
        super(_fieldId);

       
    }

]]></Source>
			</Method>
			<Method>
				<Name>BinRateDisplay</Name>
				<Source><![CDATA[
    /// <summary>
    /// to display bin rate
    /// </summary>
    public display PurchPrice BinRateDisplay()
    {
        if(this.BinQtyOriginal !=0)
        {
            return round(this.BinRate /this.BinQtyOriginal,0.01);
        }
        else
        {
            return 0;
        }
    }

]]></Source>
			</Method>
