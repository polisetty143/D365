		<Methods>
			<Method>
				<Name>getInventTransOperationFieldIdFromInventDimFieldId</Name>
				<Source><![CDATA[
    /// <summary>
    /// Gets the related field of <c>ETGSPAINInventTransOperation</c> based on the field id of <c>InventDim</c>.
    /// </summary>
    /// <param name="_inventDimFieldId">
    /// The field id of <c>InventDim</c>.
    /// </param>
    /// <returns>
    /// The field id of <c>ETGSPAINInventTransOperation</c>.
    /// </returns>
    public static FieldId getInventTransOperationFieldIdFromInventDimFieldId(FieldId _inventDimFieldId)
    {
        #InventDimDevelop

        switch (fieldExt2Id(_inventDimFieldId))
        {
            case fieldNum(InventDim,ConfigId)         : return fieldNum(ETGSPAINInventTransOperation,ConfigId);
            case fieldNum(InventDim,InventSizeId)     : return fieldNum(ETGSPAINInventTransOperation,InventSizeId);
            case fieldNum(InventDim,InventColorId)    : return fieldNum(ETGSPAINInventTransOperation,InventColorId);
            case fieldNum(InventDim,InventStyleId)    : return fieldNum(ETGSPAINInventTransOperation,InventStyleId);
            case fieldNum(InventDim,InventVersionId)  : return fieldNum(ETGSPAINInventTransOperation,InventVersionId);
            case fieldNum(InventDim,InventSiteId)     : return fieldNum(ETGSPAINInventTransOperation,InventSiteId);
            case fieldNum(InventDim,InventLocationId) : return fieldNum(ETGSPAINInventTransOperation,InventLocationId);
            case fieldNum(InventDim,InventBatchId)    : return fieldNum(ETGSPAINInventTransOperation,InventBatchId);
            case fieldNum(InventDim,wmsLocationId)    : return fieldNum(ETGSPAINInventTransOperation,wmsLocationId);
            case fieldNum(InventDim,wmsPalletId)      : return fieldNum(ETGSPAINInventTransOperation,wmsPalletId);
            case fieldNum(InventDim,InventSerialId)   : return fieldNum(ETGSPAINInventTransOperation,InventSerialId);
            case fieldNum(InventDim,LicensePlateId)   : return fieldNum(ETGSPAINInventTransOperation,LicensePlateId);
            case fieldNum(InventDim,InventStatusId)   : return fieldNum(ETGSPAINInventTransOperation,InventStatusId);
            case fieldNum(InventDim,InventDimension1) : return fieldNum(ETGSPAINInventTransOperation,InventDimension1);
            case fieldNum(InventDim,InventDimension2) : return fieldNum(ETGSPAINInventTransOperation,InventDimension2);
            case fieldNum(InventDim,InventDimension3) : return fieldNum(ETGSPAINInventTransOperation,InventDimension3);
            case fieldNum(InventDim,InventDimension4) : return fieldNum(ETGSPAINInventTransOperation,InventDimension4);
            case fieldNum(InventDim,InventDimension5) : return fieldNum(ETGSPAINInventTransOperation,InventDimension5);
            case fieldNum(InventDim,InventDimension6) : return fieldNum(ETGSPAINInventTransOperation,InventDimension6);
            case fieldNum(InventDim,InventDimension7) : return fieldNum(ETGSPAINInventTransOperation,InventDimension7);
            case fieldNum(InventDim,InventDimension8) : return fieldNum(ETGSPAINInventTransOperation,InventDimension8);
            case fieldNum(InventDim,InventDimension9) : return fieldNum(ETGSPAINInventTransOperation,InventDimension9);
            case fieldNum(InventDim,InventDimension10): return fieldNum(ETGSPAINInventTransOperation,InventDimension10);
            case fieldNum(InventDim,InventDimension11): return fieldNum(ETGSPAINInventTransOperation,InventDimension11);
            case fieldNum(InventDim,InventDimension12): return fieldNum(ETGSPAINInventTransOperation,InventDimension12);
            // <GEERU>
            case fieldNum(InventDim,InventGtdId_RU)    : return fieldNum(ETGSPAINInventTransOperation,InventGTDId_RU);
            case fieldNum(InventDim,InventProfileId_RU): return fieldNum(ETGSPAINInventTransOperation,InventProfileId_RU);
            case fieldNum(InventDim,InventOwnerId_RU)  : return fieldNum(ETGSPAINInventTransOperation,InventOwnerId_RU);
            // </GEERU>
        }

        throw error("@ETGSPAINLabels:UnknownInventoryDimension");
    }

]]></Source>
