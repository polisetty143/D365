        if(ret && this.BOLNo && ETGACFParameters::find().EnableBLNumberUniqueValidation == NoYes::Yes)
        {
            if(this.ParmId)
            {
                select firstonly Ordering from salesParmTable
                    where salesParmTable.ParmId == this.ParmId;

                if(salesParmTable.Ordering != DocumentStatus::Invoice)
