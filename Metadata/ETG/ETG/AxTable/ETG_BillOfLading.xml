			<Method>
				<Name>validateField</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <param name = "_fieldIdToCheck"></param>
    /// <returns></returns>
    public boolean validateField(FieldId _fieldIdToCheck)
    {
        SalesParmTable salesParmTable;
        boolean ret;
    
        ret = super(_fieldIdToCheck);
    
        if(ret && this.BOLNo && ETGACFParameters::find().EnableBLNumberUniqueValidation == NoYes::Yes)
        {
            if(this.ParmId)
            {
                select firstonly Ordering from salesParmTable 
                    where salesParmTable.ParmId == this.ParmId;

                if(salesParmTable.Ordering != DocumentStatus::Invoice)
                {
                    ret = ETGBLNumberUniqueValidation::checkBLNum(this.BOLNo, this.DataAreaId, ModuleSalesPurch::Sales, this.SalesId);
                }
            }
        }

        return ret;
    }

]]></Source>
