			<Method>
				<Name>modifiedField</Name>
				<Source><![CDATA[
    public void modifiedField(FieldId _fieldId)
    {
        super(_fieldId);

        if (_fieldId == fieldNum(ETGGrainReceiptCharges, ChargeMarkupCode))
        {
            MarkupTable chargeMaster;

            select firstonly chargeMaster
            where chargeMaster.MarkupCode == this.ChargeMarkupCode;

            if (chargeMaster)
            {
                this.Description = chargeMaster.Txt;
            }
            else
            {
                this.Description = '';
            }
        }
    }

]]></Source>
