				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public display VendName sellerName()
    {
        Name    vendName;

        if (this.SellerAccountNum)
        {
            vendName = VendTable::find(this.SellerAccountNum).name();
        }

        return vendName;
    }

]]></Source>
