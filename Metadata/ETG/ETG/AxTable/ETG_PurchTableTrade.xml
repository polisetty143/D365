				<Name>buyerName</Name>
				<Source><![CDATA[
    public display Name buyerName()
    {
        Name    buyerName;

        if (this.BuyerAccountNum)
        {
            buyerName = Companyinfo::findDataArea(this.BuyerAccountNum).name();           
        }

        return buyerName;
    }

]]></Source>
