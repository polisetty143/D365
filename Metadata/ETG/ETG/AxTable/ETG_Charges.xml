    public void modifiedField(FieldId _fieldId)
    {
        SalesLine salesline;

        super(_fieldId);
        switch(_fieldId)
         {
             case fieldNum(ETG_Charges, ETG_Amount):
                 select * from salesline where salesline.RecId == this.SalesLine;
                 if(salesline)
                 {
                     this.ETG_Quantity =this.ETG_Amount / salesline.SalesQty;
                 }


                 break;
         }
         }

