			<Method>
				<Name>postLoad</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public void postLoad()
    {
        LogisticsPostalAddress logisticsPostalAddress;
        CustPackingSlipJour custPackingSlipJour;
        ETG_BillOfLading billOfLading;
        InventDim inventDim;
        InventTable inventTable;
        str packing;
        
        ETG_SalesTableTrade ETG_SalesTableTradeOrg;
        SalesTable salesTable;
        SalesLine salesLine;

        super();

        select * from logisticsPostalAddress
            where logisticsPostalAddress.RecId == this.DeliveryPostalAddress;

        this.DeliveryAddress = logisticsPostalAddress.Address;

        custPackingSlipJour = CustPackingSlipJour::findFromCustPackingSlipTrans(this.SalesId, this.PackingSlipId, this.DeliveryDate);

        this.BillOfLadingId = custPackingSlipJour.BillOfLadingId;
        this.BOLCarrierName = custPackingSlipJour.BOLCarrierName;
        this.DeliveryName = custPackingSlipJour.DeliveryName;
        // this.BOLPackageAppearance = custPackingSlipJour.BOLPackageAppearance;//
        this.DlvMode = custPackingSlipJour.DlvMode;
        this.DlvTerm = custPackingSlipJour.DlvTerm;

        select * from billOfLading
            where billOfLading.SalesId == custPackingSlipJour.SalesId
            && billOfLading.PackingSlipId == custPackingSlipJour.PackingSlipId;
        // && billOfLading.DeliveryDate == custPackingSlipJour.DeliveryDate;

        this.BOLNo = billOfLading.BOLNo;
        this.BOLDate = billOfLading.BOLDate;
        this.CarrierId = billOfLading.CarrierId;//
        this.BOLCarrierName = billOfLading.CarrierCode;//
        this.BOLPackageAppearance = enum2Str(billOfLading.PackageAppearance);//
        this.NetWeight = billOfLading.NetWeight;
        this.GrossWeight = billOfLading.GrossWeight;
        this.NumberOfBags = billOfLading.NumberOfBags;
        this.NumberOfContainers = billOfLading.NumberOfContainers;//
        this.ContainerNumber = billOfLading.ContainerNumber;
        this.AgentSealNum = billOfLading.AgentSealNum;

        select * from inventDim
            where inventDim.inventDimId == this.InventDimId;

        // this.configId = inventDim.InventSizeId;
        // packing = inventDim.InventSizeId;;
        this.Packing = inventDim.InventSizeId;

        select * from inventTable
            where inventTable.ItemId == this.ItemId;

        this.ETGMainCommodity = inventTable.ETGCommodity;

        select * from ETG_SalesTableTradeOrg
            where ETG_SalesTableTradeOrg.SalesId == this.SalesId;

        this.ShipmentFrom = ETG_SalesTableTradeOrg.FromDatePort;
        this.ShipmentTo = ETG_SalesTableTradeOrg.ToDatePort;

        select * from salesTable
            where salesTable.SalesId == this.SalesId;

        this.SalesAgreementId = SalesAgreementHeader::find(salesTable.MatchingAgreement).SalesNumberSequence;

        select * from salesLine where salesLine.SalesId == this.SalesId
            && salesLine.ItemId == this.ItemId;

        this.ETGRefSalesId = salesLine.ETGRefSalesId;

        this.PortOfLoadingDesc = ETG_SalesTableTradeOrg.PortOfLoadingDesc;
        this.PortOfDischargeDesc = ETG_SalesTableTradeOrg.PortOfDischargeDesc;
    }

]]></Source>
			</Method>
			<Method>
				<Name>salesAgreementId</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    [SysClientCacheDataMethodAttribute(true)]
    public static str salesAgreementId()
    {
        str salesIdOrg = SysComputedColumn::returnField(
        dataentityviewstr(ETGCustPackingSlipTransEntity),
        dataEntityDataSourceStr(ETGCustPackingSlipTransEntity, CustPackingSlipTrans), // alias for SalesTable in the SQL
        fieldStr(CustPackingSlipTrans, SalesId));

        return strFmt(@"
        (select top 1 SALESNUMBERSEQUENCE
         from AGREEMENTHEADER a
         join SALESTABLE ST on ST.MATCHINGAGREEMENT = a.RECID
         where ST.SalesId = %1)", salesIdOrg);
        
    
    }

]]></Source>
			</Method>
