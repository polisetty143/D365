		<Methods>
			<Method>
				<Name>postLoad</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public void postLoad()
    {
        super();
        this.ProductName            = InventTable::find(this.ItemId).itemName();
        this.Vertical     = ETGFixedAssetFinancialsDimensions::getDimensionDisplayValue(this.DefaultDimension, "Vertical");
        this.SubVertical  = ETGFixedAssetFinancialsDimensions::getDimensionDisplayValue(this.DefaultDimension, "BusinessUnit");
        this.Commodity    = ETGFixedAssetFinancialsDimensions::getDimensionDisplayValue(this.DefaultDimension, "MainCommodity");
        this.SubCommodity = ETGFixedAssetFinancialsDimensions::getDimensionDisplayValue(this.DefaultDimension, "SubCommodity");
        this.Itemdim         = ETGFixedAssetFinancialsDimensions::getDimensionDisplayValue(this.DefaultDimension, "ItemId");
        this.ItemGroup              = InventItemGroup::find(InventItemGroupItem::findByItemIdLegalEntity(this.ItemId, curExt()).ItemGroupId).Name;
        InventItemGroupForm inventItemGroupForm;

        select firstonly LedgerDimension from inventItemGroupForm
            where inventItemGroupForm.ItemGroupId == this.ItemGroup
                && inventItemGroupForm.InventAccountType == InventAccountType::InventIssue;

        DefaultDimensionView defaultDimensionView;

        select firstonly defaultDimensionView
            where defaultDimensionView.DefaultDimension == this.DefaultDimension
            && defaultDimensionView.Name == 'MainAccount';


        this.MainAccount            = defaultDimensionView.DisplayValue;
        DimensionAttributeValue dimAttributeValue;
        select * from dimAttributeValue where dimAttributeValue.DisplayValue == this.MainAccount  ;

        this.MainAccountName        = dimAttributeValue.getName();









    }

]]></Source>
			</Method>
		</Methods>
	</SourceCode>
