    /// <summary>
    ///
    /// </summary>
  



    /// <summary>
    ///
    /// </summary>
    public void postLoad()
    {
        super();
        

            ETGGENERALJOURNALACCOUNTENTRYENTITY gjEntry;
            MainAccount mainAccount;

            select firstOnly gjEntry
        where gjEntry.Voucher == this.Voucher &&
              gjEntry.DataAreaId == this.DataAreaId &&
              gjEntry.PostingType != 14;

            if (gjEntry)
            {
                select firstOnly mainAccount
            where mainAccount.RecId == gjEntry.MainAccount;

                if (mainAccount)
                {
                    this.MainAccount = mainAccount.MainAccountId;
                }
            }
        

    }

]]></Source>
