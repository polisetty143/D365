    /// <summary>
    /// get the customer name
    /// </summary>
    /// <returns>
    /// Customer Name
    /// </returns>
    public static str getEntityStdName()
    {
       
        SysDictTable    custTable       = new SysDictTable(tableNum(CustTable));
        SysDictTable    dirPartyTable   = new SysDictTable(tableNum(DirPartyTable));

        str custId = SysComputedColumn::returnField(tablestr(ETGSalesLineBiEntity),
                                                                               dataEntityDataSourceStr(ETGSalesLineBiEntity,SalesLine ),
                                                                               fieldstr(ETGSalesLineBiEntity, CustAccount));


        const str queryExp = 'SELECT top 1 %1 from %2 join %5 on %5.%4 = %2.%6 where %5.%7 = %3';
        return strFmt(queryExp,
                dirPartyTable.fieldName(fieldNum(DirPartyTable,KnownAs), DbBackend::Sql),
                dirPartyTable.name(DbBackend::Sql),
                custId,
                custTable.fieldName(fieldNum(CustTable,Party), DbBackend::Sql),
                custTable.name(DbBackend::Sql),
                dirPartyTable.fieldName(fieldNum(DirPartyTable, RecId), DbBackend::Sql),
                custTable.fieldName(fieldNum(CustTable, AccountNum), DbBackend::Sql)
                );
      
    }

