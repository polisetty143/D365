		<Methods>
			<Method>
				<Name>transactionCreditAmount</Name>
				<Source><![CDATA[
    /// <summary>
    /// Gets the transaction credit amount.
    /// </summary>
    /// <returns>A sql case statement representing the conversion from the TransactionCurrencyAmount field
    /// to the TransactionCurrencyCreditAmount field.</returns>
    /// <remarks>
    /// Example case statement for the field:
    ///    ( Cast (( CASE
    ///            WHEN T1.iscredit = 1 THEN ( T1.transactioncurrencyamount )
    ///            * ( N'-1' )
    ///            ELSE N'0'
    ///         END ) AS NUMERIC(32, 16)) ) AS
    ///     TRANSACTIONCURRENCYCREDITAMOUNT
    /// </remarks>
    public static str transactionCreditAmount()
    {
        str isCredit = SysComputedColumn::equalExpression(
            SysComputedColumn::comparisonField(
                tableStr(GeneralJournalAccountEntryEntity),
                tableStr(GeneralJournalAccountEntry),
                fieldStr(GeneralJournalAccountEntry, IsCredit)),
            '1');

        str transactionAmountField = SysComputedColumn::returnField(
                tableStr(GeneralJournalAccountEntryEntity),
                tableStr(GeneralJournalAccountEntry),
                fieldStr(GeneralJournalAccountEntry, TransactionCurrencyAmount));

        str reverseSign = SysComputedColumn::multiply(
            transactionAmountField,
            SysComputedColumn::returnLiteral('-1'));

        return SysComputedColumn::if(
            isCredit,
            reverseSign,
            SysComputedColumn::returnLiteral('0')
        );
    }

]]></Source>
			</Method>
			<Method>
				<Name>transactionDebitAmount</Name>
				<Source><![CDATA[
    /// <summary>
    /// Gets the transaction debit amount.
    /// </summary>
    /// <returns>A sql case statement representing the conversion from the TransactionCurrencyAmount field
    /// to the TransactionCurrencyDebitAmount field.</returns>
    /// <remarks>
    /// Example case statement for the field:
    ///     ( Cast (( CASE
    ///         WHEN T1.iscredit = 0 THEN T1.transactioncurrencyamount
    ///         ELSE N'0'
    ///         END ) AS NUMERIC(32, 16)) ) AS TRANSACTIONCURRENCYDEBITAMOUNT
    /// </remarks>
    public static str transactionDebitAmount()
    {
        str isDebit = SysComputedColumn::equalExpression(
            SysComputedColumn::comparisonField(
                tableStr(GeneralJournalAccountEntryEntity),
                tableStr(GeneralJournalAccountEntry),
                fieldStr(GeneralJournalAccountEntry, IsCredit)),
            '0');

        str transactionAmountField = SysComputedColumn::returnField(
                tableStr(GeneralJournalAccountEntryEntity),
                tableStr(GeneralJournalAccountEntry),
                fieldStr(GeneralJournalAccountEntry, TransactionCurrencyAmount));

        return SysComputedColumn::if(
            isDebit,
            transactionAmountField,
            SysComputedColumn::returnLiteral('0')
        );
    }

]]></Source>
			</Method>
			<Method>
				<Name>defaultCTQuery</Name>
				<Source><![CDATA[
    /// <summary>
    /// A change tracking query used by DMF to determine what values have changed in the specified data sources since the last export.
    /// </summary>
    /// <returns>A query that represents the data sources used by the entity.</returns>
    public static Query defaultCTQuery()
    {
        Query changeTrackingQuery = new Query();

        // None of the child data sources can be "changed" (including dimensions) for the posted GL data
        QueryBuildDataSource generalJournalAccountEntryQBDS = changeTrackingQuery.addDataSource(tableNum(GeneralJournalAccountEntry));

        QueryBuildDataSource generalJournalEntryQBDS = generalJournalAccountEntryQBDS.addDataSource(tableNum(GeneralJournalEntry));
        generalJournalEntryQBDS.joinMode(JoinMode::InnerJoin);
        generalJournalEntryQBDS.relations(true);

        return changeTrackingQuery;
    }

]]></Source>
