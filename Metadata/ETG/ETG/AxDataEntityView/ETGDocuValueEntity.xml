				<Source><![CDATA[
    public void mapEntityToDataSource(
        DataEntityRuntimeContext _entityCtx,
        DataEntityDataSourceRuntimeContext _dataSourceCtx)
    {
        switch (_dataSourceCtx.name())
        {
            case dataEntityDataSourceStr(ETGDocuValueEntity, DocuValue):
                if (ETGACFParameters::find().EnableDMSIntegration == NoYes::Yes)
                {
                    DocuValue docuValue = _dataSourceCtx.getBuffer();
                    ETGDocuValueEntity entityRecord = _entityCtx.getEntityRecord();

                    if (entityRecord.ETGUpdatedPath)
                    {
                        docuValue.Path = entityRecord.ETGUpdatedPath;
                    }
                }

                break;
        }
    }

]]></Source>
