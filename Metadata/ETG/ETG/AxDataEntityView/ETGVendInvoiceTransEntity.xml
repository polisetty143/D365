			<Method>
				<Name>postLoad</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public void postLoad()
    {
        VendBankAccount vendBankAccount;
        ETG_PurchTableTrade ETG_PurchTableTradeOrg;
        VendInvoiceJour vendInvoiceJour;
        PurchTable purchTable;
        LogisticsPostalAddress logisticsPostalAddress;
        InventTable inventTable;
        PurchAgreementHeader purchAgreementHeader;
        PurchLine purchLine;

        super();

        select * from vendInvoiceJour
            where vendInvoiceJour.PurchId == this.PurchID
            && vendInvoiceJour.InvoiceId == this.InvoiceId
            && vendInvoiceJour.InvoiceDate == this.InvoiceDate
            && vendInvoiceJour.numberSequenceGroup == this.numberSequenceGroup
            && vendInvoiceJour.InternalInvoiceId == this.InternalInvoiceId;

        this.InvoiceAccount = vendInvoiceJour.InvoiceAccount;
        this.DueDate        = vendInvoiceJour.DueDate;

        select * from vendBankAccount
            where vendBankAccount.VendAccount == this.InvoiceAccount;

        this.ETGBankAccountID  = vendBankAccount.AccountID;
        this.ETGBankAccountNum = vendBankAccount.AccountNum;
        this.ETGBankName       = vendBankAccount.Name;
        this.ETGBankAddress    = vendBankAccount.addressing();

        select * from ETG_PurchTableTradeOrg
            where ETG_PurchTableTradeOrg.PurchId == this.PurchID;

        this.PortOfLoadingDesc = ETG_PurchTableTradeOrg.PortOfLoadingDesc;
        this.PortOfDischargeDesc = ETG_PurchTableTradeOrg.PortOfDischargeDesc;
        this.POLCountry = ETG_PurchTableTradeOrg.PortOfLoading;
        this.PODCountry = ETG_PurchTableTradeOrg.PortOfDischarge;
        this.NotifyToDifferentParty = ETG_PurchTableTradeOrg.Notifytodifferentparty;
        this.CountryOfOriginOfGoods = ETG_PurchTableTradeOrg.CountryOfOriginOfGoods;
        this.CountryOfFinalDestination = ETG_PurchTableTradeOrg.CountryOfFinalDestination;
        this.BuyerBank = ETG_PurchTableTradeOrg.BuyerBank;
        this.SellerBank = ETG_PurchTableTradeOrg.SellerBank;

        select * from purchTable
            where purchTable.PurchId == this.PurchID;

        this.VendorName = purchTable.PurchName;
        this.DeliveryType   = purchTable.DeliveryType;
       // this.BillToName = purchTable.editbi
        select * from logisticsPostalAddress
            where logisticsPostalAddress.RecId == this.DeliveryPostalAddress;

        this.DeliveryAddress = logisticsPostalAddress.Address;
        this.BillToAddress = logisticsPostalAddress.Address;
        this.BillToName = this.DeliveryName;

        select * from inventTable
            where inventTable.ItemId == this.ItemId;

        this.ETGMainCommodity = inventTable.ETGCommodity;

        select * from purchAgreementHeader
            where purchAgreementHeader.RecId == purchTable.MatchingAgreement;

        this.ETGPurchaseAgreementId = purchAgreementHeader.PurchNumberSequence;
        
        select * from purchLine 
            where purchLine.PurchId == this.PurchID
            && purchLine.ItemId == this.ItemId;

        this.ItemDescription = purchLine.Name;
    }

]]></Source>
			</Method>
			<Method>
				<Name>purchAgreementId</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    [SysClientCacheDataMethodAttribute(true)]
    public static str purchAgreementId()
    {
        str purchIdOrg = SysComputedColumn::returnField(
        dataentityviewstr(ETGVendInvoiceTransEntity),
        dataEntityDataSourceStr(ETGVendInvoiceTransEntity, VendInvoiceTrans), 
        fieldStr(VendInvoiceTrans, PurchId));

        return strFmt(@"
        (select top 1 PURCHNUMBERSEQUENCE
         from AGREEMENTHEADER a
         join PURCHTABLE PT on PT.MatchingAgreement = a.RECID
         where PT.PurchId = %1)", purchIdOrg);
        
    
    }

]]></Source>
			</Method>
