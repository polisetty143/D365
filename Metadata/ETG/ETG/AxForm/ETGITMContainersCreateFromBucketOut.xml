				<Fields>
					<Field>
						<DataField>ShipContainerId</DataField>
						<Methods>
							<Method>
								<Name>modified</Name>
								<Source><![CDATA[
            /// <summary>
            /// throws error when ShipContainerId is not unique.
            /// </summary>
            public void modified()
            {
                ITMLine itmLine;

                super();

                select firstonly RecId from itmLine
                    where itmLine.ShipContainerId == ITMContainers.ShipContainerId;

                if (itmLine.RecId)
                {
                    ITMContainers.ShipContainerId = '';
                    throw error('@ETG_New:UniqueShipContainerId');
                }
            }

]]></Source>
