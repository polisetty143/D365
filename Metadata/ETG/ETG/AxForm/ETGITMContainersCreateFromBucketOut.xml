		<Methods xmlns="">
			<Method>
				<Name>classDeclaration</Name>
				<Source><![CDATA[
[Form]
public class ETGITMContainersCreateFromBucketOut extends FormRun
{
    private ETGITMAddBucketContainerFormHandlerOut addBucketContainerForm;
    private ETGITMCreatorCreateShipmentTaskBaseOut createShipment;
    private boolean batchFeatureEnabled;

}
]]></Source>
			</Method>
			<Method>
				<Name>canClose</Name>
				<Source><![CDATA[
    public boolean canClose()
    {
        if (element.closedOk() && ITMContainers::exist(ITMContainers.ShipId, ITMContainers.ShipContainerId))
        {
            return checkFailed(strfmt("@InboundTransportationManagement:ContainerAlreadyExistOnShipment", ITMContainers.ShipContainerId, ITMContainers.ShipId));
        }
    
        if (!element.closedOk())
        {
            return true;
        }

        if (batchFeatureEnabled)
        {
            createShipment.parmITMContainers(ITMContainers);
        }
        else
        {
            addBucketContainerForm.addToNewContainerProcess(ITMContainers);
        }

        return super();
    }

]]></Source>
			</Method>
			<Method>
				<Name>closeOk</Name>
				<Source><![CDATA[
    public void closeOk()
    {
        if (!batchFeatureEnabled || createShipment.checkCloseDialog())
        {
            super();
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    public void init()
    {
        if (element.args().caller() is ETGITMAddBucketContainerFormHandlerOut)
        {
            addBucketContainerForm = element.args().caller();
        }
        else if (element.args().caller() && element.args().caller().runbase() is ETGITMCreatorCreateShipmentTaskBaseOut)
        {
            createShipment = element.args().caller().runbase();
            addBucketContainerForm = createShipment.parmITMAddBucketContainerFormHandler();
        }
        else
        {
            throw error("@SYS22539");
        }

        super();

        batchFeatureEnabled = addBucketContainerForm.parmBatchFeatureEnabled();
        DialogContent.visible(!batchFeatureEnabled);
        Tab.visible(batchFeatureEnabled);
        addBucketContainerForm.initCreateContainerForm();

        if (ITMAddToContainerBatchJobFeature::instance().isEnabled())
        {
            element.design().dialogSize(DialogSize::Medium);
        }
    }

]]></Source>
			</Method>
