		<DataControls xmlns="">
			<Control>
				<Name>Post</Name>
				<Type>Button</Type>
				<Methods>
					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        public void clicked()
        {
            super();

            
            if (!ETGHapayPurchTable.RecId)
            {
                Info("No header record selected.");
                return;
            }

            
            if (ETGHapayPurchTable.Reference_Number)
            {
                Warning("Purchase Order is already created for this record.");
                return;
            }

            ttsbegin;
            try
            {
                PurchTable        purchTable;
                PurchLine         purchLine;
                ETGHapayPurchLine lineDataSource;
                NumberSeq         numberSeq;
                VendTable         vendTable;
                DirPartyTable     dirPartyTable;
               
                
                purchTable.initValue();
                numberSeq = NumberSeq::newGetNum(PurchParameters::numRefPurchId());
                purchTable.PurchId        = numberSeq.num();
                purchTable.PurchName = ETGHapayPurchTable.VendorName;

                select firstOnly vendTable
                              join dirPartyTable
                                 where vendTable.Party == dirPartyTable.RecId
                               && dirPartyTable.Name == purchTable.PurchName;

                if (vendTable)
                {
                    purchTable.OrderAccount   = vendTable.AccountNum;
                    purchTable.VendGroup      = vendTable.VendGroup;
                }
               
                purchTable.LanguageId     =  "en-US";
                purchTable.InvoiceAccount = purchTable.OrderAccount;
                purchTable.CurrencyCode   = ETGHapayPurchTable.CurrencyCode;
                purchTable.DlvMode        = lineDataSource.DlvMode;
                purchTable.DlvTerm        = lineDataSource.DlvTerm;
                purchTable.DefaultDimension = ETGHapayPurchTable.DimensionDefault;

             
                if (purchTable.validateWrite())
                {
                    purchTable.insert();
                }
                else
                {
                    throw error("Failed to validate purchase header. Check vendor account and other mandatory fields.");
                }

               
                ETGHapayPurchTable.selectForUpdate(true);
                ETGHapayPurchTable.Reference_Number = purchTable.PurchId;
                ETGHapayPurchTable.update();

                
                for (lineDataSource = ETGHapayPurchLine_DS.getFirst() as ETGHapayPurchLine; lineDataSource; lineDataSource = ETGHapayPurchLine_DS.getNext() as ETGHapayPurchLine)
                {
                    purchLine.clear();
                    purchLine.initValue();

                    purchLine.PurchId = purchTable.PurchId; 

                    
                    purchLine.ItemId     = lineDataSource.ItemId;
                
                

                    
                    InventDim inventDim;
                    inventDim.InventSiteId     = lineDataSource.InventSiteId;
                    inventDim.InventLocationId = lineDataSource.InventLocationId;
                    inventDim.configId         = lineDataSource.configId;
                    inventDim.InventSizeId     = lineDataSource.InventSizeId;
                    inventDim.InventColorId    = lineDataSource.InventColorId;
                    inventDim.InventStyleId    =  lineDataSource.InventStyleId;
                    purchLine.InventDimId      = InventDim::findOrCreate(inventDim).inventDimId;
        
                    
                    purchLine.createLine(true, true, true, true, true, true);
                    purchLine.selectForUpdate(true);
                    purchLine.PurchQty   = lineDataSource.PurchQty;
                    purchLine.PurchPrice = lineDataSource.PurchPrice;
                    purchLine.LineAmount = purchLine.PurchQty * purchLine.PurchPrice;

                    purchLine.update();


                    
                    lineDataSource.selectForUpdate(true);
                    lineDataSource.Reference_Number = purchTable.PurchId;
                    lineDataSource.update();
                }

                ttscommit;
                
                Info(strFmt("Purchase order %1 created successfully.", purchTable.PurchId));

                ETGHapayPurchTable_ds.reread();  // Re-read current record from DB
                ETGHapayPurchTable_ds.refresh(); // Refresh display
                ETGHapayPurchTable_ds.active();  // Force execution of active() method to disable button
            }
            catch (Exception::Error)
            {
                ttsabort;
                Error("An error occurred while posting the purchase order.");
            }
        }

]]></Source>
