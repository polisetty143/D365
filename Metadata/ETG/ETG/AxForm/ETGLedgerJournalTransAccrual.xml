				<Source><![CDATA[
[Form]
public class ETGLedgerJournalTransAccrual extends FormRun
{
    LedgerJournalTrans      ledgerJournalTrans;

    [FormObservable]
    TransDate               oldTransDate;
    [FormObservable]
