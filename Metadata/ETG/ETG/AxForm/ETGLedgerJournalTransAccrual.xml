						<Source><![CDATA[
        public void initValue()
        {
            super();

            switch (element.args().dataset())
            {
                case tablenum(LedgerJournalTrans):
                    etgLedgerJournalTransAccrual.initFromLedgerJournalTrans(LedgerJournalTrans::findRecId(etgLedgerJournalTransAccrual.RefRecid, false), element.args().caller().ledgerJournalEngine());
                    oldAccountOffsetaccount = etgLedgerJournalTransAccrual.AccountOffsetaccount;
                    break;
            }
        }

