                oldEndDate = etgLedgerJournalTransAccrual.calcEndDate();
                oldTransDate = etgLedgerJournalTransAccrual.TransDate;
                oldAccrualId = etgLedgerJournalTransAccrual.AccrualId;
            }

            return oldEndDate;
        }

