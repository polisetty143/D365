	<SourceCode>
		<Methods xmlns="">
			<Method>
				<Name>classDeclaration</Name>
				<Source><![CDATA[
/// <summary>
/// This form extension handles operations related to purchase orders for the ETGSPAIN module.
/// It includes methods to manage the status of operations, such as closing or reverting them, and controls UI elements accordingly.
/// </summary>
[Form]
public class ETGSPAINPurchOperationTable extends FormRun
{
    AgreementHeader  agreementHeader;

}
]]></Source>
			</Method>
			<Method>
				<Name>parmAgreementHeader</Name>
				<Source><![CDATA[
    /// <summary>
    /// Sets or gets the <c>agreementHeader</c> parameter.
    /// </summary>
    /// <param name = "_agreementHeader">Instance of <c>AgreementHeader</c></param>
    /// <returns>Returns the current value of <c>agreementHeader</c></returns>
    /// <remarks>
    /// The <c>AgreementHeader</c> is used during the creation of contracts.
    /// </remarks>
    public AgreementHeader parmAgreementHeader(AgreementHeader _agreementHeader = agreementHeader)
    {
        agreementHeader = _agreementHeader;

        return agreementHeader;
    }

]]></Source>
			</Method>
			<Method>
				<Name>closeOperation</Name>
				<Source><![CDATA[
    /// <summary>
    /// Closes the operation by setting the status to Closed.
    /// </summary>
    private void closeOperation()
    {        
        ETGSPAINPurchOperationTable.OperationStatus = ETGSPAINOperationStatus::Closed;              
    }

]]></Source>
			</Method>
			<Method>
				<Name>revertOperation</Name>
				<Source><![CDATA[
    /// <summary>
    /// Reverts the operation status.
    /// If there are executions, the status will be set to "Execution"; otherwise, it reverts to "Open".
    /// </summary>
    private void revertOperation()
    {
        ETGSPAINPurchOperationTable.OperationStatus = (ETGSPAINPurchOperationTable.hasExecutions())   ?  
                                                    ETGSPAINOperationStatus::Execution           :
                                                    ETGSPAINOperationStatus::Open;
    }

]]></Source>
			</Method>
		</Methods>
		<DataSources xmlns="">
			<DataSource>
				<Name>ETGSPAINPurchOperationTable</Name>
				<Methods>
					<Method>
						<Name>active</Name>
						<Source><![CDATA[
        /// <summary>
        /// Triggered each time the data source is activated.
        /// It controls the availability of buttons based on the operation status.
        /// </summary>
        /// <returns>Returns an integer result from the base method.</returns>
        public int active()
        {
            int ret;
    
            ret = super();

            switch (ETGSPAINPurchOperationTable.OperationStatus)
            {
            
                case ETGSPAINOperationStatus::Closed:
                    SalesAgreementForNew.enabled(false);
                    PurchAgreementForNew.enabled(false);
                    ClosedButton.enabled(false);
                    RevertButton.enabled(true);
                    break;
                case ETGSPAINOperationStatus::Open:
                    SalesAgreementForNew.enabled(true);
                    PurchAgreementForNew.enabled(true);
                    ClosedButton.enabled(true);
                    RevertButton.enabled(false);
                    break;
                case ETGSPAINOperationStatus::Execution:
                    SalesAgreementForNew.enabled(true);
                    PurchAgreementForNew.enabled(true);
                    ClosedButton.enabled(true);
                    RevertButton.enabled(false);
                    break;
            }            

            return ret;
        }

]]></Source>
					</Method>
				</Methods>
				<Fields />
			</DataSource>
		</DataSources>
