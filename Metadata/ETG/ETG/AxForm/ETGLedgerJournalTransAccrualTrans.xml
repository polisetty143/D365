					<Method>
						<Name>executeQuery</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void executeQuery()
        {
            criteriaPosted.value(element.valueAllOpenPosted());

            ETGLedgerJournalTransAccrualTrans_ds.query().dataSourceTable(tableNum(ETGLedgerJournalTransAccrualTrans)).clearRange(fieldNum(ETGLedgerJournalTransAccrualTrans, AccrualId));

            if (AccrualId.valueStr())
            {                
                ETGLedgerJournalTransAccrualTrans_ds.query().dataSourceTable(tableNum(ETGLedgerJournalTransAccrualTrans)).addRange(fieldNum(ETGLedgerJournalTransAccrualTrans, AccrualId)).value(AccrualId.valueStr());
            }

       //     ETGLedgerJournalTransAccrualTrans_ds..queryBuildDataSource().addSortField(fieldNum(SysDataBaseLog,CreatedDateTime),SortOrder::Descending);
       ETGLedgerJournalTransAccrualTrans_ds.query().dataSourceTable(tableNum(ETGLedgerJournalTransAccrualTrans)).addSortField(fieldNum(ETGLedgerJournalTransAccrualTrans, TransDate), SortOrder::Ascending);

            super();

            ETGLedgerJournalTransAccrualTrans_ds.allowEdit(!ETGLedgerJournalTransAccrualTrans.Posted);
        }

]]></Source>
