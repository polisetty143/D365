					<Method>
						<Name>deleteMarked</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void deleteMarked()
        {
            RefRecId refRecId;
            TransDate transDate;
            int counter = 0;

            MultiSelectionHelper helper = MultiSelectionHelper::construct();

            helper.parmDatasource(this);

            ETGLedgerJournalTransAccrualTrans eTGLedgerJournalTransAccrualTransLoc = helper.getFirst();

            refRecId = eTGLedgerJournalTransAccrualTransLoc.RefRecid;
            transDate = eTGLedgerJournalTransAccrualTransLoc.TransDate;

            eTGLedgerJournalTransAccrualTransLoc = helper.getNext();

            if (eTGLedgerJournalTransAccrualTransLoc && !eTGLedgerJournalTransAccrualTransLoc.Posted)
            {
                if (!(refRecId == eTGLedgerJournalTransAccrualTransLoc.RefRecid) ||
                    !(transDate == eTGLedgerJournalTransAccrualTransLoc.TransDate))
                {
                    throw error('Selected records cannot be deleted. Please select related records with same trans date and refrecid');
                }
                else
                {
                    eTGLedgerJournalTransAccrualTransLoc = helper.getNext();

                    if (eTGLedgerJournalTransAccrualTransLoc)
                    {
                        throw error('Records can be deleted only in pair');
                    }
                }
            }
            else
            {
                throw error('Records can be deleted only in pair');
            }

            super();
        }

]]></Source>
