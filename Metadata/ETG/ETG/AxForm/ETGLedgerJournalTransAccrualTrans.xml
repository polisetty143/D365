			<Method>
				<Name>valueAllOpenPosted</Name>
				<Source><![CDATA[
    /// <summary>
    /// Returns a query range value for the journal status to filter on.
    /// </summary>
    /// <returns>A string with query range value.</returns>
    protected str valueAllOpenPosted()
    {
        switch (AllOpenPostedField.selection())
        {
            case AllOpenPosted::All     : 
                ETGLedgerJournalTransAccrualTrans_ds.allowDelete(false);
                return SysQuery::valueUnlimited();
            case AllOpenPosted::Open    : 
                ETGLedgerJournalTransAccrualTrans_ds.allowDelete(true);
                return enum2Value(NoYes::No);
            case AllOpenPosted::Posted  :
                ETGLedgerJournalTransAccrualTrans_ds.allowDelete(false);
                return enum2Value(NoYes::Yes);

            default: return SysQuery::valueUnlimited();
        }
    }

]]></Source>
