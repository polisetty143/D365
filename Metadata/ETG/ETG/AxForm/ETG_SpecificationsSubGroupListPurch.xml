                ETG_ProductReceiptQualityGrp_ds.object(fieldNum(ETG_ProductReceiptQualityGrp, MinRange)).enabled(ETG_ProductReceiptQualityGrp.MeasurementType == CalculationType::Percentage);

            }
        }

