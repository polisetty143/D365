                || PurchLine::find(ETG_ProductReceiptQualityGrp.InventTransId).purchTable().DocumentState == VersioningDocumentState::Confirmed)
            {
                ETG_ProductReceiptQualityGrp_ds.allowEdit(false);
            }
            else
            {
                ETG_ProductReceiptQualityGrp_ds.object(fieldNum(ETG_ProductReceiptQualityGrp, Increment)).enabled(ETG_ProductReceiptQualityGrp.MeasurementType == CalculationType::Percentage);
