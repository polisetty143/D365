						<Source><![CDATA[
        display Description  QualitygroupIdDescription()
        {
            ETGQualitySpecificationSubGroup qualitySpecificationSubGroup;
            
            select firstonly qualitySpecificationSubGroup
                where qualitySpecificationSubGroup.SubGroupID == ETG_ProductReceiptQualityGrp.SubGroupId;

            return qualitySpecificationSubGroup.SubGroupDescription;
        }

]]></Source>
