        public void executeQuery()
        {
            QueryBuildDataSource  queryBuildDataSource;
 
            queryBuildDataSource = this.query().dataSourceTable(tablenum(LedgerJournalTable));
            queryBuildDataSource.clearRanges();

            if(DestinationEntity.valueStr())
            {
                queryBuildDataSource.addRange(fieldnum(LedgerJournalTable,ETGICDestinationEntity)).value(queryValue(DestinationEntity.valueStr()));
                queryBuildDataSource.addRange(fieldnum(LedgerJournalTable,Posted)).value(queryValue(Status.valueStr()));

                if(Fromdate.valueStr() && ToDate.valueStr())
                {
                    
                    queryBuildDataSource.addRange(fieldnum(LedgerJournalTable,CreatedDateTime)).value(SysQuery::range(Fromdate.dateValue(),ToDate.dateValue()));
                }
                
            }
            else
            {
                queryBuildDataSource.addRange(fieldnum(LedgerJournalTable,ETGICDestinationEntity)).value(queryValue("ABC"));
            }
            

            super();

        }

