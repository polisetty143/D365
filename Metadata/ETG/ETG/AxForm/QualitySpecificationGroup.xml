        public boolean modified()
        {
            ETGQualitySpecificationSubGroup      etgQualitySpecificationSubGroup;

            boolean ret;
        
            ret = super();

            select firstonly etgQualitySpecificationSubGroup
                where etgQualitySpecificationSubGroup.SubGroupID == ETGQualitySpecificationLine.SubGroupID;

            if(ETGQualitySpecificationLine.SubGroupID)
            {
                ETGQualitySpecificationLine.SubGroupDescription = etgQualitySpecificationSubGroup.SubGroupDescription;
            }
            return ret;
        }

