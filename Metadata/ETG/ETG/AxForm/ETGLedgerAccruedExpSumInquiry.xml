				<Source><![CDATA[
[Form]
public class ETGLedgerAccruedExpSumInquiry extends FormRun
{
    ETGLedgerAccruedExpSumInquiryForm  ledgerAccruedExpSumInquiryForm;
    ETGLedgerAccruedExpSumDetailsTmp   ledgerAccruedExpSumDetailsTmp;

    FiscalCalendar      fiscalCalendar;
    FiscalCalendarRecId initialCalendarRecId;
    FiscalYearName      fiscalYear;
    boolean             pendingAccruedTransactionsFilter;
}
]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    public void init()
    {
        initialCalendarRecId = Ledger::fiscalCalendar();
        fiscalCalendar = FiscalCalendar::find(initialCalendarRecId);

        super();

        ledgerAccruedExpSumInquiryForm = new ETGLedgerAccruedExpSumInquiryForm();

        PendingAccruedTransactions.value(true);
        pendingAccruedTransactionsFilter = true;
    }

]]></Source>
			</Method>
			<Method>
				<Name>setTableData</Name>
				<Source><![CDATA[
    private void setTableData()
    {
        //FormDataSource ds = this.dataSource(formDataSourceStr(ETGLedgerAccruedExpSumInquiry, ETGLedgerAccruedExpSumDetailsTmp));
        if (this.validateParameters())
        {
            ETGLedgerAccruedExpSumDetailsTmp.linkPhysicalTableInstance(ledgerAccruedExpSumInquiryForm.populateVendPrepaymentDetailsTmp(
                fiscalCalendar,
                fiscalYear,
                pendingAccruedTransactionsFilter));

            ETGLedgerAccruedExpSumDetailsTmp_ds.research();
            //ds.research();
            Info ("@HGITLabel:OperationCompleted");
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>validateParameters</Name>
				<Source><![CDATA[
    private boolean validateParameters()
    {
        boolean ret = true;
        
        if (fiscalYear == "")
        {            
            ret = checkFailed(strfmt("@HGITLabel:FieldMustBeFilledIn", strLwr(extendedTypeId2pname(extendedTypeNum(FiscalYearName)))));
        }
        
        return ret;
    }

]]></Source>
			</Method>
			<Method>
				<Name>clearData</Name>
				<Source><![CDATA[
    private void clearData()
    {
        delete_from ETGLedgerAccruedExpSumDetailsTmp;

        ETGLedgerAccruedExpSumDetailsTmp_ds.executeQuery();
    }

]]></Source>
