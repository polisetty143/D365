			<Method>
				<Name>inventDimSetupObject</Name>
				<Source><![CDATA[
    private Object inventDimSetupObject()
    {
        return inventDimFormSetup;
    }

]]></Source>
			</Method>
			<Method>
				<Name>updateDesign</Name>
				<Source><![CDATA[
    private void updateDesign(InventDimFormDesignUpdate _mode)
    {
        switch (_mode)
        {
            case InventDimFormDesignUpdate::Init:
                if (!inventDimFormSetup)
                {
                    inventDimFormSetup = InventDimCtrl_Frm::newFromFormOutboundETG(element);
                }
                inventDimFormSetup.parmSkipOnHandLookUp(true);
    
            case InventDimFormDesignUpdate::Active:
                inventDimFormSetup.formSetControls(true);
                break;
    
            default:
                throw error(strFmt("@SYS54195", funcName()));
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    public void init()
    {
        if (element.args().caller() is ETGITMEditorFormHandlerOut)
        {
            shipEditorForm = element.args().caller();

            ITMTable = shipEditorForm.parmITMTable();
        }
        else
        {
            throw error("@SYS22539");
        }

        super();

        LineGrid_ShipDataArea.allowEdit(false);

        element.initForm();

        element.initAddBucketContainerForm();
    }

]]></Source>
			</Method>
			<Method>
				<Name>initForm</Name>
				<Source><![CDATA[
    private void initForm()
    {
        ExistingContainerTabPage.caption(strFmt("@InboundTransportationManagement:ExistContainerInShipment", ITMTable.ShipId));

        ITMTmpCreatorLine.setTmpData(shipEditorForm.parmTmpCreatorLine());

        element.updateDesign(InventDimFormDesignUpdate::Init);
    }

]]></Source>
			</Method>
			<Method>
				<Name>initAddBucketContainerForm</Name>
				<Source><![CDATA[
    private void initAddBucketContainerForm()
    {
        addBucketContainerForm = ETGITMAddBucketContainerFormHandlerOut::newFromForm(element);
        addBucketContainerForm.parmITMTable(ITMTable);
        addBucketContainerForm.parmTmpCreatorLine(ITMTmpCreatorLine);
        addBucketContainerForm.parmITMContainers(ITMContainers);
    }

]]></Source>
			</Method>
			<Method>
				<Name>close</Name>
				<Source><![CDATA[
    public void close()
    {
        shipEditorForm.runFillTables();

        super();
    }

]]></Source>
