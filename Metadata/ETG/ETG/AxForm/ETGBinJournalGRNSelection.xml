        public void clicked()
        {
            ETGBinJournalLine _ETGBinJournalLineRec;
            FormDataSource  ds;
       
        
            _ETGBinJournalLineRec = element.args().record();
            super();
            VendPackingSlipTrans        VendPackingSlipTransLoc;
            VendPackingSlipTransLoc = VendPackingSlipTrans_DS.getFirst(1);
            while (VendPackingSlipTransLoc.RecId != 0)
            {
                ETGGlobal::TransferToBin(VendPackingSlipTransLoc.RecId,_ETGBinJournalLineRec.recid);
                VendPackingSlipTransLoc = VendPackingSlipTrans_DS.getNext();
            }

            Info(strFmt('GRN Qty has been added in to Line Batch info form for the selected record.',_ETGBinJournalLineRec.JournalId));

            element.close();
          
