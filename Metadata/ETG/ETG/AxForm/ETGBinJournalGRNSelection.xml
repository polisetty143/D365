						<Methods>
							<Method>
								<Name>modified</Name>
								<Source><![CDATA[
            /// <summary>
            ///
            /// </summary>
            public void modified()
            {
                if(VendPackingSlipTrans.ETGQtyRequired < 0)
                {
                    throw error(strFmt('Quantity Required can not be accept negative value.'));
                }

                super();
                if(VendPackingSlipTrans.ETGQtyRequired > VendPackingSlipTrans.ETGQtyBalance)
                {
                    throw error(strFmt('Quantity Required %1 can not be more than %2 .',VendPackingSlipTrans.ETGQtyRequired,VendPackingSlipTrans.ETGQtyBalance));
                }
            }

]]></Source>
