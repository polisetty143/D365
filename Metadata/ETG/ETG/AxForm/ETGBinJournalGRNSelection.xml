        public display VendAccount VendorCode()
        {
            PurchTable  PurchTable;

            select PurchTable
                where PurchTable.PurchId == VendPackingSlipTrans.OrigPurchid;
            return VendTable::find(PurchTable.OrderAccount).AccountNum;
        }

