			<Method>
				<Name>refreshCaller</Name>
				<Source><![CDATA[
    public void refreshCaller()
    {
        FormRun        formRulCaller         = element.args().caller();
        FormDataSource inventJournalTrans_ds = formRulCaller.datasource(tableNum(InventJournalTrans));
        if (inventJournalTrans_ds)
        {
            inventJournalTrans_ds.refresh();
            inventJournalTrans_ds.research(true);
        }
        else
        {
            FormDataSource InventJournalTable_ds = formRulCaller.datasource(tableNum(InventJournalTable));
            if(InventJournalTable_ds)
            {
                InventJournalTable_ds.research(true);
                InventJournalTable_ds.refresh();
                InventJournalTable_ds.rereadReferenceDataSources();
            }
        }
    }

]]></Source>
			</Method>
		</Methods>
		<DataSources xmlns="" />
		<DataControls xmlns="">
			<Control>
				<Name>OK</Name>
				<Type>CommandButton</Type>
				<Methods>
					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        public void clicked()
        {
            InventJournalTable inventJournalTableLoc;
            InventJournalTrans inventJournalTransLoc, inventJournalTransCheck;
            VendInvoiceTrans vendInvoiceTransLoc;
            VendInvoiceJour vendInvoiceJourMarked;
            VendInvoiceTrans vendInvoiceTransSelected;
            boolean isAnyRecordSelected;
            int lineCount;
            MultiSelectionHelper multiSelectionHelper = MultiSelectionHelper::construct();
            //multiSelectionHelper.parmDatasource(VendInvoiceJour_ds);
            multiSelectionHelper.parmDatasource(VendInvoiceTrans_ds);
            

            
            inventJournalTableLoc = element.args().record();
            if (!inventJournalTableLoc || inventJournalTableLoc.RecId == 0)
            {
                warning("No journal selected or found.");
                return;
            }

            ttsBegin;

            vendInvoiceTransSelected = multiSelectionHelper.getFirst() as VendInvoiceTrans;
          //  vendInvoiceJourMarked = multiSelectionHelper.getFirst() as VendInvoiceJour;

            while (vendInvoiceTransSelected)
            {
                vendInvoiceJourMarked = vendInvoiceTransSelected.vendInvoiceJour();
                //while select vendInvoiceTransSelected
                //    where vendInvoiceTransSelected.InvoiceId == vendInvoiceJourMarked.InvoiceId
                //    && vendInvoiceTransSelected.InvoiceDate == vendInvoiceJourMarked.InvoiceDate
                //{
                    inventJournalTransLoc.clear();
                    inventJournalTransLoc.initValue();
                    inventJournalTransLoc.initFromInventJournalTable(inventJournalTableLoc);
                    select maxof(LineNum) from inventJournalTransCheck where inventJournalTransCheck.JournalId == inventJournalTableLoc.JournalId;
                    inventJournalTransLoc.initFromInventTable(InventTable::find(vendInvoiceTransSelected.ItemId));
                    inventJournalTransLoc.LineNum       = inventJournalTransCheck.LineNum + 1;
                    inventJournalTransLoc.Qty           = (-1) * vendInvoiceTransSelected.Qty;
                    inventJournalTransLoc.modifiedField(fieldNum(InventJournalTrans, Qty));
                    inventJournalTransLoc.PriceUnit     = vendInvoiceTransSelected.PriceUnit;
                    //inventJournalTransLoc.TransDate     = vendInvoiceTransSelected.InvoiceDate
                    inventJournalTransLoc.TransDate     =  DateTimeUtil::getSystemDate(DateTimeUtil::getUserPreferredTimeZone());
                    inventJournalTransLoc.JournalType   = InventJournalType::Transfer;
                    inventJournalTransLoc.InventDimId   = vendInvoiceTransSelected.InventDimId;
                    inventJournalTransLoc.ToInventDimId = vendInvoiceTransSelected.InventDimId;
                    inventJournalTransLoc.ETGTransferJournalPurchId = vendInvoiceTransSelected.PurchID;
                    inventJournalTransLoc.ETGTransferJournalPurchInvoiceId = vendInvoiceTransSelected.InvoiceId;
                    inventJournalTransLoc.ETGToDefaultDimension  = vendInvoiceTransSelected.DefaultDimension;
                    inventJournalTransLoc.ETGTransferJournalInvoicetransid = vendInvoiceTransSelected.InventTransId;
                    try
                    {
                        inventJournalTransLoc.insert();
                        isAnyRecordSelected++;
                    }
                    catch (Exception::Error)
                    {
                        error(strFmt("Error occured while creating journal line for Item: %1", vendInvoiceTransSelected.ItemId));
                        ttsAbort;
                        return;
                    }
               // }
                vendInvoiceTransSelected = multiSelectionHelper.getNext() as VendInvoiceTrans;
            }

            ttsCommit;
            element.refreshCaller();
            element.close();
            info("Journal lines created successfully.");
        }

]]></Source>
