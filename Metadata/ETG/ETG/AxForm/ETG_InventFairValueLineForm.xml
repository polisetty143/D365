			<Method>
				<Name>showHideColumns</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public void showHideColumns(ETG_InventFairValueHeaderTable _inventFairValueHeaderTable)
    {
        ;
        _inventFairValueHeaderTable.reread();
        ETG_InventFairValueLineTable_ds.object(fieldNum(ETG_InventFairValueLineTable,configId)).visible(_inventFairValueHeaderTable.Grade);
        ETG_InventFairValueLineTable_ds.object(fieldNum(ETG_InventFairValueLineTable,InventSizeId)).visible(_inventFairValueHeaderTable.Size);
        ETG_InventFairValueLineTable_ds.object(fieldNum(ETG_InventFairValueLineTable,InventColorId)).visible(_inventFairValueHeaderTable.Origin);
        ETG_InventFairValueLineTable_ds.object(fieldNum(ETG_InventFairValueLineTable,InventStyleId)).visible(_inventFairValueHeaderTable.Brand);
        ETG_InventFairValueLineTable_ds.object(fieldNum(ETG_InventFairValueLineTable,InventSiteId)).visible(_inventFairValueHeaderTable.Site);
        ETG_InventFairValueLineTable_ds.object(fieldNum(ETG_InventFairValueLineTable,WMSLocationId)).visible(_inventFairValueHeaderTable.Warehouse);
        ETG_InventFairValueLineTable_ds.object(fieldNum(ETG_InventFairValueLineTable,InventLocationId)).visible(_inventFairValueHeaderTable.Location);
        ETG_InventFairValueLineTable_ds.object(fieldNum(ETG_InventFairValueLineTable,InventBatchId)).visible(_inventFairValueHeaderTable.BatchNumber);
        if(ETG_InventFairValueLineTable.RecId!=0)
        {
            ETG_InventFairValueLineTable_ds.allowCreate(false);
        }
        else
            ETG_InventFairValueLineTable_ds.allowCreate(true);
    }

]]></Source>
