        public int active()
        {
            int ret;
        
            ret = super();
            if(inventFairValueHeaderTable.JournalNumber != null)
            {
                //ETG_InventFairValueLineTable.FairRate().editable(false); 
                ETG_InventFairValueLineTable_ds.object(fieldNum(ETG_InventFairValueLineTable,FairRate)).allowEdit(true);
            }
        
            return ret;
        }

]]></Source>
