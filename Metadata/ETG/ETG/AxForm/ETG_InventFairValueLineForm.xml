						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void executeQuery()
        {
            inventFairValueHeaderTable.data(element.args().record());
            super();
            select ETG_InventFairValueLineTable 
                where  ETG_InventFairValueLineTable.FairValuationSerialNumber == inventFairValueHeaderTable.FairValuationSerialNumber;
            element.showHideColumns(inventFairValueHeaderTable);
        }

]]></Source>
