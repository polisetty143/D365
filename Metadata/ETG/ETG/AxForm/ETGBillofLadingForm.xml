				<Methods>
					<Method>
						<Name>lookup</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void lookup()
        {
            SysTableLookup sysTableLookup = SysTableLookup::newParameters(tableNum(ETGRailCarLoadingTable),this);
            Query query                   = new Query();
            QueryBuildDataSource            qbds;

            qbds                          = query.addDataSource(tableNum(ETGRailCarLoadingTable));
            qbds.addRange(fieldNum(ETGRailCarLoadingTable, DataAreaId)).value(curExt());

            sysTableLookup.parmQuery(query);

            sysTableLookup.addLookupfield(fieldNum(ETGRailCarLoadingTable, ETGRailLoadingSerialNumber), true);

            sysTableLookup.performFormLookup();

        }

]]></Source>
