						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        /// <returns></returns>
        public int active()
        {
            int ret;
            ret = super();
            Confirm.enabled(ETGBillofLadingTable.ETGBOLStatus       == ETGBOLStatus::Draft);
            ChangeRequest.enabled(ETGBillofLadingTable.ETGBOLStatus == ETGBOLStatus::Confirmed);
            if(ETGBillofLadingTable.ETGBOLStatus == ETGBOLStatus::Draft)
            {
                ETGBillofLadingTable_ds.allowEdit(true);
            }
            else
            {
                ETGBillofLadingTable_ds.allowEdit(false);
            }
            PrintReciept.enabled(ETGBillofLadingTable.ETGBOLStatus   == ETGBOLStatus::Confirmed);
            ETGBillofLadingTable_ds.allowDelete(ETGBOLStatus::Draft);
            return ret;

        }

]]></Source>
