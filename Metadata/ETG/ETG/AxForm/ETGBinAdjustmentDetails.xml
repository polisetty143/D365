					<Method>
						<Name>create</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        /// <param name = "_append"></param>
        public void create(boolean _append = false)
        {
            super(_append);

            ETGBinJournalLine       ETGBinJournalLine;

            select ETGBinJournalLine where ETGBinJournalLine.RecId == ETGBinAdjustmentDetails.BinJournalLine;

            ETGBinAdjustmentDetails.ItemId = ETGBinJournalLine.ItemId;    
            ETGBinAdjustmentDetails.ToBatch = ETGBinJournalLine.ToBatch;
        }

]]></Source>
					</Method>
					<Method>
						<Name>active</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        /// <returns></returns>
        public int active()
        {
            int ret;
        
            ret = super();

            ETGBinAdjustmentDetails_ds.allowEdit(ETGBinAdjustmentDetails.TransferJRNId == '');
            ETGBinAdjustmentDetails_ds.allowDelete(ETGBinAdjustmentDetails.TransferJRNId == '');

            ETGBinJournalLine       ETGBinJournalLine;

            select ETGBinJournalLine where ETGBinJournalLine.RecId == ETGBinAdjustmentDetails.BinJournalLine;

            if(ETGBinJournalLine.RecId && ETGBinJournalLine.BinFGRNLocked == NoYes::Yes)
            {
                ETGBinAdjustmentDetails_ds.allowCreate(false);
            }
        
            return ret;
        }

]]></Source>
					</Method>
				</Methods>
