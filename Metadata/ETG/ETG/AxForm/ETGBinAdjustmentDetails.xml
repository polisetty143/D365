		<DataControls xmlns="">
			<Control>
				<Name>CreateAdjustment</Name>
				<Type>Button</Type>
				<Methods>
					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void clicked()
        {

            if(InventParameters::find().ETGBinAdjustmentJrnName == '')
            {
                throw error(strFmt('%1','Define the Bin Adjustment Journal Name setup in Inventory Parameter setup.'));
            }
            super();

            if(ETGBinAdjustmentDetails.TransferJRNId == '')
            {
                ETGGlobal::CreateBinAdjustment(ETGBinAdjustmentDetails.RecId);
                ETGBinAdjustmentDetails_ds.research(true);
            }
        }

]]></Source>
					</Method>
