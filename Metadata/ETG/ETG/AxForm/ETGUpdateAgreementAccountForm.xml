					<Method>
						<Name>onUploadCompleted</Name>
						<Source><![CDATA[
        public void onUploadCompleted()
        {
            FileUploadTemporaryStorageResult result = this.getFileUploadResult() as FileUploadTemporaryStorageResult;

            if (result && result.getUploadStatus())
            {
                // Use openResult() instead of getFileStream()
                System.IO.Stream fileStream = result.openResult();
        
                if (fileStream)
                {
                    // Pass the stream and the selected module enum to our service class
                    ETGAgreementUpdateModule selectedModule = ModuleSelection.selection();
            
                    ETGUpdateAgreementAccountService::processExcel(fileStream, selectedModule);

                    // Best Practice: Close the stream after use if processExcel doesn't handle it
                    fileStream.Close();
                }
            }
            else
            {
                error("File upload failed.");
            }
        }

]]></Source>
					</Method>
				</Methods>
			</Control>
