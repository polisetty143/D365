						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        /// <param name = "_append"></param>
        public void create(boolean _append = false)
        {
            ETGCostDistributionsHeader newRecord;
            ETGCostAllocationRuleId   _ruleId;

            super(_append);

            _ruleId =NumberSeq::newGetNum(LedgerParameters::numRefCostAllocationRuleIdETG(),true).num();

