				<Methods>
					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void clicked()
        {
            super();

            ETGCostDistributionsLines costLinesSum;
            ETGCostDistributionsHeader costheader = element.dataSource().cursor();

            select sum(ETGLinePercentage) from costLinesSum
                    where costLinesSum.ETGMainAccount == costheader.ETGMainAccount
                    && costLinesSum.ETGRefRecId == costheader.RecId;

            if(costLinesSum.ETGLinePercentage != 100)
            {
                throw error("@ETG_New:CostDistributionpercentagevalidation");
            }
            else
            {
                costheader.ETGIsDistributionConfirmed = ETGDistributionStatus::Confirmed;
                Info("@ETG_New:CostDistributionstatusconfirmed");
            }
        }

]]></Source>
