        /// <returns></returns>
        public int active()
        {
            int ret;
        
            ret = super();
            if(ETG_ActualAgreementNew.Posted == NoYes::Yes)
            {
                CreateActual.enabled(false);
                FormGridControl1.allowEdit(false);
            }
            else
            {
                CreateActual.enabled(true);
                FormGridControl1.allowEdit(true);
            }
        
            return ret;
        }

