			<Method>
				<Name>classDeclaration</Name>
				<Source><![CDATA[
[Form]
public class ETGRateCardMaster extends FormRun
{
    AgreementLineRecId agreementLineRecId;
}
]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public void init()
    {
        AgreementLine agreementLine;

        super();

        if(element.args() && element.args().dataset() == tableNum(AgreementLine) && element.args().record())
        {
            agreementLine      = element.args().record();
            agreementLineRecId = agreementLine.RecId;
        }

        ETGRateCardMasterHelper rateCardMasterHelper = ETGRateCardMasterHelper::construct();
        rateCardMasterHelper.parmAgreementLine(agreementLine);
        rateCardMasterHelper.run();
    }

]]></Source>
			</Method>
		</Methods>
		<DataSources xmlns="">
			<DataSource>
				<Name>ETGRateCardMaster</Name>
				<Methods>
					<Method>
						<Name>active</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        /// <returns></returns>
        public int active()
        {
            int ret;
        
            ret = super();

            if(ETGRateCardMaster.IsConfirmed == NoYes::Yes)
            {
                ETGRateCardMaster_ds.allowEdit(false);
            }
        
            return ret;
        }

]]></Source>
					</Method>
					<Method>
						<Name>executeQuery</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void executeQuery()
        {
            if(agreementLineRecId)
            {
                SysQuery::findOrCreateRange(this.queryBuildDataSource(), fieldNum(ETGRateCardMaster, RefRecId)).value(queryValue(agreementLineRecId));
            }
            super();
        }

]]></Source>
					</Method>
				</Methods>
				<Fields />
			</DataSource>
		</DataSources>
		<DataControls xmlns="">
			<Control>
				<Name>Confirm</Name>
				<Type>Button</Type>
				<Methods>
					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void clicked()
        {
            ETGRateCardMaster rateCardMaster;
            super();

            DialogButton db;

            db = Box::yesNo("After confirmation you will not be able to make changes. Do you want to confirm?", dialogButton::Yes, "Confirm rate card");
            if (db == dialogButton::Yes)
            {
                ttsbegin;

                update_recordset rateCardMaster
                    setting IsConfirmed = NoYes::Yes
                        where rateCardMaster.RefRecId == ETGRateCardMaster.RefRecId
                        && rateCardMaster.DataAreaId == ETGRateCardMaster.DataAreaId
                        && rateCardMaster.ModuleSalesPurch == ModuleSalesPurch::Purch
                        && (rateCardMaster.DiscPct != 0 || rateCardMaster.DiscAmount != 0);

                ttscommit;

                ETGRateCardMaster_ds.research(true);
                ETGRateCardMaster_ds.refresh();
                ETGRateCardMaster_ds.active();
                info("Rate card is confirmed");
            }
        }

]]></Source>
					</Method>
				</Methods>
			</Control>
