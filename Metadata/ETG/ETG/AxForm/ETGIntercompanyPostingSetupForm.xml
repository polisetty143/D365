			<Method>
				<Name>createReciprocalRelationship</Name>
				<Source><![CDATA[
    private void createReciprocalRelationship(ETGIntercompanyPostingSetup _ETGIntercompanyPostingSetup)
    {
        boolean found;
        found = (
            select firstonly RecId
                from ETGIntercompanyPostingSetup
                    where ETGIntercompanyPostingSetup.DestinationCompany == _ETGIntercompanyPostingSetup.DestinationCompany &&
                        ETGIntercompanyPostingSetup.OriginatingCompany == _ETGIntercompanyPostingSetup.OriginatingCompany).RecId != 0;

        if(found)
        {
            throw error(strFmt("@Ledger:InterCompanyRelationshipExists", _ETGIntercompanyPostingSetup.DestinationCompany, _ETGIntercompanyPostingSetup.OriginatingCompany));
        }

        ETGIntercompanyPostingSetup ledgerInterCompanyLocal = _ETGIntercompanyPostingSetup.data(_ETGIntercompanyPostingSetup);

        ETGIntercompanyPostingSetup_DS.create();
        
        ETGIntercompanyPostingSetup newLedgerInterCompany = ETGIntercompanyPostingSetup_DS.cursor();
        ETGIntercompanyPostingSetup_DS.positionToRecord(newLedgerInterCompany);

        newLedgerInterCompany.OriginatingCompany = ledgerInterCompanyLocal.DestinationCompany;
        newLedgerInterCompany.DestinationCompany = ledgerInterCompanyLocal.OriginatingCompany;
        newLedgerInterCompany.OriginatingCreditLedgerDimension = ledgerInterCompanyLocal.DestinationCreditLedgerDimension;
        newLedgerInterCompany.OriginatingDebitLedgerDimension = ledgerInterCompanyLocal.DestinationDebitLedgerDimension;
        newLedgerInterCompany.DestinationCreditLedgerDimension = ledgerInterCompanyLocal.OriginatingCreditLedgerDimension;
        newLedgerInterCompany.DestinationDebitLedgerDimension = ledgerInterCompanyLocal.OriginatingDebitLedgerDimension;
        newLedgerInterCompany.JournalName = ledgerInterCompanyLocal.JournalName;
    }

]]></Source>
