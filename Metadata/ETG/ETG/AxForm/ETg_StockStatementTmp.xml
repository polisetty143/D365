					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void clicked()
        {
            ETg_StockStatementTmp       stockStatementTmp;
            ETG_StockStatementEngine    stockStatementEngine = new ETG_StockStatementEngine();

            super();

            if (this.validateParameters())
            {
                stockStatementEngine.parmFromDate(fromDateValue.dateValue());
                stockStatementEngine.parmToDate(toDateValue.dateValue());
                stockStatementEngine.parmIsSite(Site.value());
                stockStatementEngine.parmIsWarehouse(Warehouse.value());
                stockStatementEngine.parmIsLocation(Location.value());
                stockStatementEngine.parmItemId(ItemId.valueStr());
                stockStatementEngine.parmIsBatch(Batch.value());
                stockStatementEngine.parmIsSerial(Serial.value());
                stockStatementTmp = ETG_StockStatementEngine::insStockMovementTmp(stockStatementEngine);
                ETg_StockStatementTmpDS.linkPhysicalTableInstance(stockStatementTmp);
                ETg_StockStatementTmpDS_ds.research();
            }
            element.hideElements();
        }

]]></Source>
					</Method>
					<Method>
						<Name>validateParameters</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public boolean validateParameters()
        {
            boolean     validation = true;

            if (fromDateValue.dateValue() == dateNull())
            {
                validation  = warning("@ETG:FromDatemustbefilledin");
                validation  = false;
            }

            if (toDateValue.dateValue() == dateNull())
            {
                validation  = warning("@ETG:ToDatemustbefilledin");
                validation  = false;
            }

            return validation;
        }

]]></Source>
