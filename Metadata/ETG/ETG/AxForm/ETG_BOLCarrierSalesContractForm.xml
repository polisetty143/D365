}
]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public void init()
    {
        if(this.args().record().dataSource().name() != ('SalesAgreementHeader'))
        {
            excelSalesAgreementId = this.args().parm();
        }
        super();

        if(excelSalesAgreementId)
        {
            BOLContainerSalesAgreement_ds.query().dataSourceTable(Tablenum(ETG_BOLContainerSalesAgreement)).addRange(fieldNum(ETG_BOLContainerSalesAgreement,SalesAgreementId)).
          value(SysQuery::value(excelSalesAgreementId));
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>getSalesAgreementId</Name>
				<Source><![CDATA[
    public SalesAgreementId getSalesAgreementId()
    {
        return currSalesAgreementId;
    }

]]></Source>
			</Method>
			<Method>
				<Name>run</Name>
				<Source><![CDATA[
    public void run()
    {
        super();

        if(this.args().record().dataSource()
            && this.args().record().dataSource().name() == ('SalesAgreementHeader'))
        {
            if(this.args().parm())
            {
                currSalesAgreementId = this.args().parm();
            }
        }
    }

]]></Source>
