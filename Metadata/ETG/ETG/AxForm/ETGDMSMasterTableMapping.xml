            public void lookup(FormControl _formControl, str _filterStr)
            {
                TableId                     _tableId;
                SysTableLookup              sysTableLookup = SysTableLookup::newParameters(tablenum(SYSTABLEFIELDIDVIEW), _formControl);
                Query                       query = new Query();
                QueryBuildDataSource        queryBuildDataSource;
                QueryBuildRange             nameQBR, typeQBR;

                if(!ETGDMSMasterTableMapping.TableName)
                {
                    throw error("Please select the table name first");
                }

                _tableId = tableName2Id(ETGDMSMasterTableMapping.TableName);

                

                queryBuildDataSource = query.addDataSource(tablenum(SYSTABLEFIELDIDVIEW));

                sysTableLookup.addLookupfield(fieldnum(SYSTABLEFIELDIDVIEW, Name));
                sysTableLookup.addLookupfield(fieldnum(SYSTABLEFIELDIDVIEW, SqlName));

                SysQuery::findOrCreateRange(queryBuildDataSource, fieldNum(SYSTABLEFIELDIDVIEW, id)).value(queryValue(_tableId));

                sysTableLookup.parmQuery(query);
                sysTableLookup.performFormLookup();
            }

