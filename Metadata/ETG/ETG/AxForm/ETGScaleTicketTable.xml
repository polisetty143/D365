					<Method>
						<Name>modified</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        /// <returns></returns>
        public boolean modified()
        {
            boolean ret;
        
            ret = super();
        
            if(this.valueStr())
            {
                PurchAgreementHeader    agreementHeader = PurchAgreementHeader::findByAgreementId(this.valueStr(), ETGCanadaParameters::find().DefaultEntityForDocuments);
                ETGScaleTicketTable     scaleTicketTable = ETGScaleTicketTable_ds.cursor();
                scaleTicketTable.Producer =  agreementHeader.vendTable().name();
            }
            else
            {
                ETGScaleTicketTable     scaleTicketTable = ETGScaleTicketTable_ds.cursor();
                scaleTicketTable.Producer = "";
            }

            return ret;
        }

]]></Source>
					</Method>
				</Methods>
			</Control>
			<Control>
				<Name>ETGScaleTicketTable_PrimaryBIN</Name>
				<Type>String</Type>
				<Methods>
					<Method>
						<Name>modified</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        /// <returns></returns>
        public boolean modified()
        {
            boolean ret;
    
            ret = super();

            if(this.valueStr())
            {
                WMSLocation     WMSLocation;

                select firstonly WMSLocation
                    where WMSLocation.wMSLocationId == this.valueStr();
                
                ETGScaleTicketTable     scaleTicketTable = ETGScaleTicketTable_ds.cursor();
                scaleTicketTable.BranchLocation =  WMSLocation.inventLocation().address();
                scaleTicketTable.Location = WMSLocation.inventLocationId;
            }
            else
            {
                ETGScaleTicketTable     scaleTicketTable = ETGScaleTicketTable_ds.cursor();
                scaleTicketTable.BranchLocation = "";
            }
    
            return ret;
        }

]]></Source>
					</Method>
