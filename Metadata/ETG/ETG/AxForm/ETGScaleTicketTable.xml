        /// <summary>
        ///
        /// </summary>
        /// <returns></returns>
        public boolean modified()
        {
            boolean ret;
        
            ret = super();

            if(ETGScaleTicketTable.BIN && !msCtrl.getSelectedFieldValues())
            {
                return ret;
            }
            else
            {
                ETGScaleTicketTable.BIN = con2Str(msCtrl.getSelectedFieldValues(),' ; ');
            }
        
            return ret;
        }

]]></Source>
