				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    public void init()
    {
        super();
        Query query = new Query();
        QueryBuildDataSource qbds;

        qbds = query.addDataSource(tableNum(WMSLocation));
        qbds.fields().addField(fieldNum(WMSLocation,WMSLocationId));
        qbds.fields().addField(fieldNum(WMSLocation,InventLocationId));

        msCtrl = SysLookupMultiSelectCtrl::constructWithQuery(element,ETGScaleTicketTable_BIN,query,false,[tableNum(WMSLocation),fieldNum(WMSLocation,WMSLocationId)]);
    }

]]></Source>
