					<Method>
						<Name>active</Name>
						<Source><![CDATA[
        /// <summary>
        /// This method enables/ disables Submit and Print buttons
        /// </summary>
        /// <returns></returns>
        public int active()
        {
            int ret = super();
            boolean submitted = (ETGScaleTicketTable.IsSubmitted == NoYes::Yes);

            ETGScaleTicketTable_ds.allowEdit(!submitted);
            SubmitButton.enabled(!submitted);
            PrintScaleTicket.enabled(submitted);

            //CS - BIN Qty Status activation - Abhinav
            PartList partList = new PartList(this.formRun());
            FormPartControl formpartcontrol = partList.getPartControlByFormName(formStr(ETGBinVolumeAvailableChartForm));
            formpartcontrol.visible(ETGCanadaParameters::find().EnableBinQtyStatus);

            if(ETGCanadaParameters::find().EnableBinQtyStatus)
            {
                InventDim inventdim,inventdimnew;
                //container binValues = str2con(ETGScaleTicketTable.BIN,';');

                inventdim.wMSLocationId = ETGScaleTicketTable.PrimaryBIN;
                inventdim.InventLocationId = ETGScaleTicketTable.Location;
                inventdimnew = InventDim::findOrCreate(inventdim);
                inventdimnew.insert();
                ETGBinQtyVisualChartHelperClass::populateBinQtyChartData(inventdimnew,formpartcontrol);
            }
            //CE

            return ret;
        }

]]></Source>
					</Method>
					<Method>
						<Name>executeQuery</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void executeQuery()
        {
            
            QueryBuildDataSource qbds;

            qbds = this.query().dataSourceTable(tableNum(ETGScaleTicketTable));

            qbds.sortClear();

            qbds.addSortField(
            fieldNum(ETGScaleTicketTable, ScaleTicketNumber),
            SortOrder::Descending);
            super();
        }

]]></Source>
