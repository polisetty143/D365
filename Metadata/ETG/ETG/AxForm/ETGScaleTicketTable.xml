				<Methods>
					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        /// <summary>
        /// This method is for Submit button clicked
        /// </summary>
        public void clicked()
        {
            DialogButton result = Box::yesNo("@ETG_New:ETGScaleTicketSubmitDialog",DialogButton::No,"@ETG_New:ETGSubmitTicket");
            if (result == DialogButton::Yes)
            {
                ttsbegin;
                ETGScaleTicketTable.IsSubmitted = NoYes::Yes;
                //ETGScaleTicketTable.validateWrite();
                ETGScaleTicketTable.update();
               
                ttscommit;

                ETGScaleTicketTable_ds.research(true);
                ETGScaleTicketTable_ds.refresh();
            }
            super();
        }

]]></Source>
