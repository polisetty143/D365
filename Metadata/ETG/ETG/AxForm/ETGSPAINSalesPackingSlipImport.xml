					<Method>
						<Name>active</Name>
						<Source><![CDATA[
        /// <summary>
        /// Overrides the <c>active</c> method to control the editability of form fields based on the record's status.
        /// </summary>
        /// <returns>Returns an integer indicating the success of the method call.</returns>
        public int active()
        {
            int ret;
        
            ret = super();

            
            boolean allowEdit = ((ETGSPAINSalesPackingSlipImport.Status == IFRUniversalInterfaceSystemStatus::Error
                                                        || ETGSPAINSalesPackingSlipImport.Status == IFRUniversalInterfaceSystemStatus::None));            
            
            //ETGSPAINSalesPackingSlipImport_ds.allowEdit(allowEdit);
            
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, ETGSPAINInventLicensePlate)).allowEdit(true);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, ETGSPAINCustSalesReference)).allowEdit(true);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, ETGSPAINInventPackingSlipTransitId)).allowEdit(true);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, ETGSPAINSalesCustomerWithdrawalDate)).allowEdit(true);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, DeliveryDate)).allowEdit(allowEdit);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, ETGSPAINSalesQtyWithdrawn)).allowEdit(allowEdit);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, ETGSPAINPurchOperationId)).allowEdit(allowEdit);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, ETGSPAINInventApplicationId)).allowEdit(false);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, ErrorLogContainer)).allowEdit(false);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, ErrorsLog)).allowEdit(false);            
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, ExecutionId)).allowEdit(false);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, InstanceRelationType)).allowEdit(false);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, InventJournalId)).allowEdit(false);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, InventSerialId)).allowEdit(allowEdit);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, InventLocationId)).allowEdit(allowEdit);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, OrderAccount)).allowEdit(false);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, PackingSlipId)).allowEdit(false);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, PackingSlipSalesId)).allowEdit(false);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, RefRecId)).allowEdit(false);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, RefTableId)).allowEdit(false);
            ETGSPAINSalesPackingSlipImport_ds.object(fieldNum(ETGSPAINSalesPackingSlipImport, Status)).allowEdit(false);

            ETGSPAINSalesPackingSlipImportPostController.enabled(!(ETGSPAINSalesPackingSlipImport.Status == IFRUniversalInterfaceSystemStatus::Posted));

            return ret;
        }

]]></Source>
