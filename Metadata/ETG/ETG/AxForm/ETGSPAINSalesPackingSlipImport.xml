/// The form class <c>ETGSPAINSalesPackingSlipImport</c> handles the import of sales packing slips for the ETGSPAIN module.
/// It manages the interaction with the sales packing slip import data, allowing edits only when certain conditions are met.
/// </summary>
[Form]
public class ETGSPAINSalesPackingSlipImport extends FormRun
{
}
