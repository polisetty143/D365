				<Source><![CDATA[
[Form]
public class ETGITMTableCreateOutbound extends FormRun
{
    private NumberSeqFormHandler numberSeqFormHandler;
    private ETGITMTableFormOutbound shipTableForm;
    private boolean foredit;

}
]]></Source>
			</Method>
			<Method>
				<Name>canClose</Name>
				<Source><![CDATA[
    public boolean canClose()
    {
        if (element.closedOk() && !ITMTable_ds.validateWrite())
        {
            return false;
        }
    
        ITMTable_ds.write();

        if(!foredit)
        {
            if (numberSeqFormHandler)
            {
                numberSeqFormHandler.formMethodClose();
            }
        }
    
        if (!element.closedOk())
        {
            return true;
        }
    
        return super();
    }

]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    public void init()
    {
        FormOpenMode FormOpenMode;

        if (element.args().caller() is ETGITMTableFormOutbound)
        {
            shipTableForm = element.args().caller();

            if (element.args().parmEnum() == FormOpenMode::ForEdit)
            {
                foredit = true;

                ITMTable = shipTableForm.parmITMTable();

            }
        }
        else
        {
            throw error("@SYS22539");
        }

        super();

        if (foredit)
        {
            element.design().caption("@InboundTransportationManagement:EditShipment");

            ITMTable_ds.autoSearch(true);

            ITMTable_ShipId.allowEdit(ITMParameters::numRefShipId().NumberSequenceId != 0);
        }

    }

]]></Source>
			</Method>
			<Method>
				<Name>numberSeqFormHandler</Name>
				<Source><![CDATA[
    public NumberSeqFormHandler numberSeqFormHandler()
    {
        if (!numberSeqFormHandler)
        {
            numberSeqFormHandler = NumberSeqFormHandler::newForm(ITMParameters::numRefShipId().NumberSequenceId,
                                                                 element,
                                                                 ITMTable_ds,
                                                                 fieldNum(ITMTable, ShipId)
                                                                );
        }
        return numberSeqFormHandler;
    }

]]></Source>
			</Method>
			<Method>
				<Name>run</Name>
				<Source><![CDATA[
    public void run()
    {
        if(!foredit)
        {
            ITMTable_ds.create();
        }
 
        super();
    }

]]></Source>
