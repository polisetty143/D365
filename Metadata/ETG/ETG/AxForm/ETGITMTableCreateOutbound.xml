				<Methods>
					<Method>
						<Name>create</Name>
						<Source><![CDATA[
        public void create(boolean _append = false)
        {
            if (!ITMTable.ShipId)
            {
                super(_append);
        
                element.numberSeqFormHandler().formMethodDataSourceCreate();
                if (shipTableForm.parmSalesTable())
                {
                    ITMTable.ShipVendAccount = shipTableForm.parmSalesTable().InvoiceAccount;
                }
            }
        }

]]></Source>
					</Method>
					<Method>
						<Name>linkActive</Name>
						<Source><![CDATA[
        public void linkActive()
        {
            element.numberSeqFormHandler().formMethodDataSourceLinkActive();
        
            super();
        }

]]></Source>
					</Method>
					<Method>
						<Name>write</Name>
						<Source><![CDATA[
        public void write()
        {
            if (!element.closedOk())
            {
                return;
            }
        
            try
            {
                if(!foredit)
                {
                    ttsBegin;
        
                    element.numberSeqFormHandler().formMethodDataSourceWrite();
        
                    ITMTable.ETGLandedCostType = ETGLandedCostType::Outbound;
                    ITMTable.insert();
        
                    ttsCommit;
                }
                else
                {
                    super();
                }
            }
            catch (Exception::Error)
            {
                ITMTable.RecId = 0;
                element.close();
                throw Exception::Error;
            }
        
            ITMTable_ds.refresh();
        
            if(!foredit)
            {
                shipTableForm.parmNewShipId(ITMTable.ShipId);
            }
        }

]]></Source>
					</Method>
					<Method>
						<Name>reread</Name>
						<Source><![CDATA[
        public void reread()
        {
            if (ITMTable.RecId)
            {
                super();
            }
        }

]]></Source>
					</Method>
					<Method>
						<Name>validateWrite</Name>
						<Source><![CDATA[
        public boolean validateWrite()
        {
            boolean ret;
        
            if (!element.closedOk())
            {
                return true;
            }
        
            if (!foredit && ITMTable::find(ITMTable.ShipId))
            {
                return checkFailed(strfmt("@InboundTransportationManagement:ShipmentValueAlreadyExistsDot", ITMTable.ShipId));
            }
        
            ret = super();
        
            if (ret && !foredit  && !element.numberSeqFormHandler().formMethodDataSourceValidateWrite())
            {
                ret = false;
            }
        
            return ret;
        }

]]></Source>
					</Method>
					<Method>
						<Name>init</Name>
						<Source><![CDATA[
        public void init()
        {
            QueryBuildRange qbrShipId;
        
            super();
        
            qbrShipId = ITMTable_ds.query().dataSourceNo(1).addRange(fieldNum(ITMTable, ShipId));
            qbrShipId.value(queryValue(ITMTable.ShipId));
            qbrShipId.status(RangeStatus::Hidden);

        }

]]></Source>
