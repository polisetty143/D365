								<Source><![CDATA[
            /// <summary>
            /// Lookup for Mother TERMO numbers on field MotherTERMOReference
            /// </summary>
            /// <param name = "_formControl">FormControl _formControl</param>
            /// <param name = "_filterStr">str _filterStr</param>
            public void lookup(FormControl _formControl, str _filterStr)
            {
                ETGTERMONumberTable::lookupMotherTermoNumber(_formControl, ETGTypeOfTERMO::Mother, ETGTERMONumberTable.ImportOrExport);
            }

