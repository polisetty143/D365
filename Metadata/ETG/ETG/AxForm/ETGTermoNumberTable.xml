								<Source><![CDATA[
            /// <summary>
            ///
            /// </summary>
            /// <param name = "_formControl"></param>
            /// <param name = "_filterStr"></param>
            public void lookup(FormControl _formControl, str _filterStr)
            {
                if(ETGTERMONumberTable.ImportOrExport == ETGImportOrExport::Import)
                {
                    ETGTERMONumberTable::lookupVendorName(_formControl);
                }
                else if(ETGTERMONumberTable.ImportOrExport == ETGImportOrExport::Export)
                {
                    ETGTERMONumberTable::lookupCustomerName(_formControl);
                }
                else
                {
                    warning("@ETG_New:PlsSelectImportExport");
                }
              
            }

