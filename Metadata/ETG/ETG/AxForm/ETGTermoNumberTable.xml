								<Source><![CDATA[
            public void modified()
            {
                super();
                ETGTERMONumberTable_ds.object(fieldNum(ETGTERMONumberTable, DateOfSubmissionOrignalDoc)).allowEdit(ETGTERMONumberTable.ClosedDate != dateNull());
                ETGTERMONumberTable_ds.object(fieldNum(ETGTERMONumberTable, DateOfOrignalDocReturrnReceived)).allowEdit(ETGTERMONumberTable.ClosedDate != dateNull());
