						<Source><![CDATA[
        /// <summary>
        /// intialize termo status
        /// </summary>
        public void initValue()
        {
            Args argsLoc = element.args();

            if(argsLoc)
            {
                if(argsLoc.menuItemName() == menuItemDisplayStr(ETGTERMONumberTableExport))
                {
                    ETGTERMONumberTable.ImportOrExport = ETGImportOrExport::Export;
                }
                if(argsLoc.menuItemName() == menuItemDisplayStr(ETGTERMONumberTableImport))
                {
                    ETGTERMONumberTable.ImportOrExport = ETGImportOrExport::Import;
                }
            }

            super();
        }

