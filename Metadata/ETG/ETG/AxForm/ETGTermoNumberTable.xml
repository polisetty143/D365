					<Method>
						<Name>executeQuery</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void executeQuery()
        {
            Args argsLoc = element.args();
            QueryBuildRange qbr;

            if(argsLoc)
            {
                qbr = SysQuery::findOrCreateRange(this.queryBuildDataSource(), fieldNum(ETGTERMONumberTable, ImportOrExport));
                qbr.status(RangeStatus::Hidden);
                if(argsLoc.menuItemName() == menuItemDisplayStr(ETGTERMONumberTableExport))
                {
                    qbr.value(SysQuery::value(ETGImportOrExport::Export));
                }
                if(argsLoc.menuItemName() == menuItemDisplayStr(ETGTERMONumberTableImport))
                {
                    qbr.value(SysQuery::value(ETGImportOrExport::Import));
                }
            }

            super();
        }

]]></Source>
