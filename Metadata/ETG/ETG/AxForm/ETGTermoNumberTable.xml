						<Source><![CDATA[
        /// <summary>
        ///This method overrides active method to make field Mother TERMO Reference mandatory, 
        ///edittable and sets initial Status of TERMO Number to Open
        /// </summary>
        /// <returns></returns>
        public int active()
        {
            int ret;
        
            ret = super();

            ETGTERMONumberTable_ds.object(fieldNum(ETGTERMONumberTable, MotherTERMOReference)).allowEdit(ETGTERMONumberTable.TypeOfTERMO == ETGTypeOfTERMO::Child);
            ETGTERMONumberTable_ds.object(fieldNum(ETGTERMONumberTable, MotherTERMOReference)).mandatory(ETGTERMONumberTable.TypeOfTERMO == ETGTypeOfTERMO::Child);
            ETGTERMONumberTable_ds.object(fieldNum(ETGTERMONumberTable, DateOfSubmissionOrignalDoc)).allowEdit(ETGTERMONumberTable.ClosedDate != dateNull());
            ETGTERMONumberTable_ds.object(fieldNum(ETGTERMONumberTable, DateOfOrignalDocReturrnReceived)).allowEdit(ETGTERMONumberTable.ClosedDate != dateNull());

            return ret;
        }

]]></Source>
