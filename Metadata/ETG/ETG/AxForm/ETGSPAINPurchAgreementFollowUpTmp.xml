/// Additionally, the form can accept a collection of records through the <c>parmRecordCollection</c> method.
/// </remarks>
[Form]
public class ETGSPAINPurchAgreementFollowUpTmp extends FormRun
{               
    Set	recordCollection;

}
]]></Source>
