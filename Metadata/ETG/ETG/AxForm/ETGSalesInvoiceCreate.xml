        /// <summary>
        ///
        /// </summary>
        public void write()
        {
            ETGSalesLines salesLines = this.cursor();
            ETGSalesHeader salestheader = ETGSalesHeader_ds.cursor();
            salesLines.ETGSalesHeaderRecId = salestheader.RecId;
            super();
            this.formRun().dataSource(2).research(true);           
        }

]]></Source>
