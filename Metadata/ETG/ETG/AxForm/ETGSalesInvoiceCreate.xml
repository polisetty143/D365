						<Name>active</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        /// <returns></returns>
        public int active()
        {
            int ret;
            ETGSalesLines salesLines;
            ETGSalesHeader salesHeader;
            InventTable inventTable;
            InventTableModule inventTableModule;
            boolean           isEditable, isMandatory;

            ret = super();

            salesLines = ETGSalesLines_ds.cursor();

            select * from salesHeader
                where salesHeader.RecId == salesLines.ETGSalesHeaderRecId;

            //if(salesLines.ETGConnectionType != ETGConnectionType::NewConnectionorCylinder)
            //{
            //    ETGSalesLines_ETGDepositAmount.allowEdit(false);
            //    //ETGSalesLines_ETGDepositAmount.value(0.00);
            //}
            //else
            //{
            //    ETGSalesLines_ETGDepositAmount.allowEdit(true);
            //}

            inventTable = InventTable::find(salesLines.ItemIdSmall);

            inventTableModule = InventTableModule::find(inventTable.ItemId, ModuleInventPurchSales::Sales);

            if(salesLines.ETGConnectionType == ETGConnectionType::NewConnectionorCylinder)
            {
                if(salesHeader.ETGBusinessSegment == ETGBusinessSegment::Domestic)
                {
                    isEditable  = true;
                    isMandatory = true;
                }
                if(salesHeader.ETGBusinessSegment == ETGBusinessSegment::Commercial
                    || salesHeader.ETGBusinessSegment == ETGBusinessSegment::Industrial
                    || salesHeader.ETGBusinessSegment == ETGBusinessSegment::Distributor)
                {
                    isEditable  = true;
                }
            }

            if(salesLines.ETGConnectionType == ETGConnectionType::Surrenderofcylinders)
            {
                if(salesHeader.ETGBusinessSegment == ETGBusinessSegment::Domestic)
                {
                    isEditable  = true;
                    isMandatory = true;
                }
                if(salesHeader.ETGBusinessSegment == ETGBusinessSegment::Commercial
                    || salesHeader.ETGBusinessSegment == ETGBusinessSegment::Industrial
                    || salesHeader.ETGBusinessSegment == ETGBusinessSegment::Distributor)
                {
                    isEditable  = true;
                }
            }

            ETGSalesLines_ETGDepositRate.allowEdit(inventTableModule.ETGDepositNeeded == NoYes::Yes && isEditable);
            ETGSalesLines_ETGDepositAmount.allowEdit(inventTableModule.ETGDepositNeeded == NoYes::Yes && isEditable);
            ETGSalesLines_ETGDepositAmount.mandatory(inventTableModule.ETGDepositNeeded == NoYes::Yes && isMandatory);
            ETGSalesLines_SalesPrice.allowEdit(inventTableModule.ETGDepositNeeded == NoYes::No);            
            ETGSalesLines_ETGFilledOrEmpty.allowEdit(inventTableModule.ETGFilledEmptyNeeded == NoYes::Yes);

            //if(inventTableModule.ETGDepositNeeded == NoYes::Yes)
            //{
            //    ETGSalesLines_ETGDepositAmount.allowEdit(true);
            //}
            //else
            //{
            //    ETGSalesLines_ETGDepositAmount.allowEdit(false);
            //}

            //if(inventTableModule.ETGFilledEmptyNeeded == NoYes::Yes)
            //{
            //    ETGSalesLines_ETGFilledOrEmpty.allowEdit(true);
            //}
            //else
            //{
            //    ETGSalesLines_ETGFilledOrEmpty.allowEdit(false);
            //}

            return ret;
        }

]]></Source>
					</Method>
