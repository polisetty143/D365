# =========================================================
# Dynamics 365 Finance & Operations (X++) .gitignore
# Only custom model SOURCE (XML) should be committed.
# Build output, binaries and generated files are excluded.
# =========================================================

# --- Build & binary artifacts ---
bin/
[Bb]in/
[Oo]bj/
XppMetadata/
Delta/
[Dd]elta/
*.dll
*.pdb
*.netmodule
*.exe
*.a2h
*.md.bak

# --- AOT / generated resources ---
# NOTE: We intentionally do NOT ignore the whole "Resources/" folder because
# model label source lives under AxLabelFile/LabelResources/ and must be kept.
*.axtrace
*.xref

# --- D365 build/compile result files (generated per build) ---
BuildModelResult.err.xml
BuildModelResult.log
BuildModelResult.xml
BuildProjectResult.err.xml
BuildProjectResult.log
BuildProjectResult.xml
CompileLabels.xml

# --- Package deployment output ---
*.zip
AXModulesBuild.*.log

# --- Visual Studio / IDE ---
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
_[Rr]esharper*/
*.[Rr]e[Ss]harper

# --- OS files ---
Thumbs.db
Desktop.ini
.DS_Store
